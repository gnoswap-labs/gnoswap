# PoC: Implicit cross-realm finalize amplification via proxy pattern
#
# Demonstrates that when a proxy realm owns data but delegates execution
# to an implementation realm, every access to the proxy's data from the
# implementation triggers implicit_cross finalize.
#
# This mimics the gnoswap staker architecture:
#   r/gnoswap/staker    (proxy)  — owns KVStore, Deposits
#   r/gnoswap/staker/v1 (impl)   — executes business logic, accesses proxy data
#   r/gnoswap/pool       (other) — cross-realm dependency
#
# PoC structure:
#   p/demo/poclib    — package providing Store type (like p/gnoswap/store)
#   r/demo/target    — another realm for cross-realm calls (like pool)
#   r/demo/proxy     — proxy realm that owns the Store
#   r/demo/impl      — implementation realm that accesses proxy's Store
#
# Scenarios:
#   A. DirectOwner:  proxy calls its own store (same realm) — no amplification
#   B. ProxyToImpl:  proxy delegates to impl which accesses proxy's store
#   C. ProxyToImplWithCross: impl accesses target cross-realm, then proxy's store
#
# Run with finalize tracing:
#   GNO_REALM_STATS_LOG=/tmp/sticky_poc.log \
#     go test -v -run TestTestdata/poc_sticky_last_realm -timeout 120s

gnoland start

## Deploy packages in dependency order: poclib → target → impl → proxy
gnokey maketx addpkg -pkgdir $WORK/poclib -pkgpath gno.land/p/demo/poclib -gas-fee 100000ugnot -gas-wanted 30000000 -broadcast -chainid=tendermint_test test1
gnokey maketx addpkg -pkgdir $WORK/target -pkgpath gno.land/r/demo/target -gas-fee 100000ugnot -gas-wanted 30000000 -broadcast -chainid=tendermint_test test1
gnokey maketx addpkg -pkgdir $WORK/impl -pkgpath gno.land/r/demo/impl -gas-fee 100000ugnot -gas-wanted 30000000 -broadcast -chainid=tendermint_test test1
gnokey maketx addpkg -pkgdir $WORK/proxy -pkgpath gno.land/r/demo/proxy -gas-fee 100000ugnot -gas-wanted 30000000 -broadcast -chainid=tendermint_test test1

### ============================================================
### Scenario A: DirectOwner
### Proxy realm directly calls its own Store (same realm owns data).
### Expected: 1 finalize (just the function return).
### ============================================================
gnokey maketx call -pkgpath gno.land/r/demo/proxy -func DirectOwner -gas-fee 1000000ugnot -gas-wanted 100000000 -broadcast -chainid=tendermint_test test1
stdout 'OK'

### ============================================================
### Scenario B: ProxyToImpl
### Proxy delegates to impl. Impl accesses proxy's Store.
### Each Store access is an implicit realm crossing (impl → proxy data).
### Expected: each store.Set/Get triggers implicit_cross finalize.
### ============================================================
gnokey maketx call -pkgpath gno.land/r/demo/proxy -func ProxyToImpl -gas-fee 1000000ugnot -gas-wanted 100000000 -broadcast -chainid=tendermint_test test1
stdout 'OK'

### ============================================================
### Scenario C: ProxyToImplWithCross
### Impl first calls target (cross-realm), then accesses proxy's Store.
### Combines cross-realm call + proxy data access.
### Expected: finalize amplification from both sources.
### ============================================================
gnokey maketx call -pkgpath gno.land/r/demo/proxy -func ProxyToImplWithCross -gas-fee 1000000ugnot -gas-wanted 100000000 -broadcast -chainid=tendermint_test test1
stdout 'OK'

-- poclib/gnomod.toml --
module = "gno.land/p/demo/poclib"
gno = "0.9"

-- poclib/store.gno --
package poclib

// Store is a package-level type that holds realm-owned data.
// Mimics p/gnoswap/store's KVStore.
type Store struct {
	data map[string]int
}

func NewStore() *Store {
	return &Store{data: make(map[string]int)}
}

func (s *Store) Get(key string) int {
	return s.data[key]
}

func (s *Store) Set(key string, val int) {
	s.data[key] = val
}

-- target/gnomod.toml --
module = "gno.land/r/demo/target"
gno = "0.9"

-- target/target.gno --
package target

var counter int

// Ping is a crossing function in another realm (like pool.GetSlot0Tick).
func Ping(cur realm) int {
	counter++
	return counter
}

-- proxy/gnomod.toml --
module = "gno.land/r/demo/proxy"
gno = "0.9"

-- proxy/proxy.gno --
package proxy

import (
	"gno.land/p/demo/poclib"
	"gno.land/r/demo/impl"
)

// store is owned by the PROXY realm.
// When impl realm accesses it, that's an implicit realm crossing.
var store = poclib.NewStore()

// DirectOwner: proxy accesses its own store directly.
// No realm boundary because the store belongs to this realm.
func DirectOwner(cur realm) string {
	store.Set("a", 1)
	store.Set("b", 2)
	store.Set("c", 3)
	_ = store.Get("a")
	_ = store.Get("b")
	_ = store.Get("c")
	return "OK"
}

// ProxyToImpl: proxy delegates to impl, passing its store.
// Impl is a different realm, so accessing proxy's store = implicit crossing.
func ProxyToImpl(cur realm) string {
	return impl.DoWork(cross, store)
}

// ProxyToImplWithCross: proxy delegates to impl which also calls target.
func ProxyToImplWithCross(cur realm) string {
	return impl.DoWorkWithCross(cross, store)
}

-- impl/gnomod.toml --
module = "gno.land/r/demo/impl"
gno = "0.9"

-- impl/impl.gno --
package impl

import (
	"gno.land/p/demo/poclib"
	"gno.land/r/demo/target"
)

// DoWork receives a Store owned by the proxy realm and operates on it.
// Each store.Set/Get call accesses proxy-realm data from impl realm context,
// which is an implicit realm crossing.
func DoWork(cur realm, store *poclib.Store) string {
	store.Set("a", 10)
	store.Set("b", 20)
	store.Set("c", 30)
	_ = store.Get("a")
	_ = store.Get("b")
	_ = store.Get("c")
	return "OK"
}

// DoWorkWithCross first calls another realm, then accesses proxy's store.
// Combines the proxy-impl crossing with a third-party realm crossing.
func DoWorkWithCross(cur realm, store *poclib.Store) string {
	_ = target.Ping(cross) // cross-realm call to target

	store.Set("a", 100)
	store.Set("b", 200)
	store.Set("c", 300)
	_ = store.Get("a")
	_ = store.Get("b")
	_ = store.Get("c")
	return "OK"
}
