# stderr 'crossing function literal.*non-realm package'

-- swap_wrapper/gnomod.toml --
module = "gno.land/r/swap_wrapper"
gno = "0.9"
-- swap_wrapper/callback.gno --
package swap_wrapper

import (
	"chain"
	"chain/runtime"
	"errors"

	"gno.land/r/gnoswap/common"
	"gno.land/r/gnoswap/pool"
)

var poolAddr = chain.PackageAddress("gno.land/r/gnoswap/pool")

func PrepareSwapCallback(
	cur realm,
	token0Path string,
	token1Path string,
	payer address,
) func(cur realm, amount0Delta, amount1Delta int64, _ *pool.CallbackMarker) error {
	return func(cur realm, amount0Delta, amount1Delta int64, _ *pool.CallbackMarker) error {
		return HandleSwapCallbackWithContext(token0Path, token1Path, payer, amount0Delta, amount1Delta)
	}
}

func HandleSwapCallbackWithContext(
	token0Path string,
	token1Path string,
	payer address,
	amount0Delta int64,
	amount1Delta int64,
) error {
	if runtime.PreviousRealm().Address() != poolAddr {
		return errors.New("unauthorized caller")
	}

	switch {
	case amount0Delta > 0:
		common.SafeGRC20TransferFrom(cross, token0Path, payer, poolAddr, amount0Delta)
	case amount1Delta > 0:
		common.SafeGRC20TransferFrom(cross, token1Path, payer, poolAddr, amount1Delta)
	}

	return nil
}

-- run/direct_pool_swap_with_wrapper_callback.gno --
package main

import (
	"chain/runtime"

	"gno.land/r/gnoswap/pool"
	"gno.land/r/swap_wrapper"
)

func main() {
	token0Path := "gno.land/r/gnoland/wugnot"
	token1Path := "gno.land/r/gnoswap/gns"
	userAddr := runtime.PreviousRealm().Address()

	callbackFn := swap_wrapper.PrepareSwapCallback(cross, token0Path, token1Path, userAddr)

	pool.Swap(
		cross,
		token0Path,
		token1Path,
		3000,
		userAddr,
		false,
		"60283363",
		"1461446703485210103287273052203988822378723970341",
		userAddr,
		callbackFn,
	)
}

-- run/direct_pool_swap_with_inline_callback.gno --
package main

import (
	"chain/runtime"

	"gno.land/r/gnoswap/pool"
	"gno.land/r/swap_wrapper"
)

func main() {
	token0Path := "gno.land/r/gnoland/wugnot"
	token1Path := "gno.land/r/gnoswap/gns"
	userAddr := runtime.PreviousRealm().Address()

	pool.Swap(
		cross,
		token0Path,
		token1Path,
		3000,
		userAddr,
		false,
		"60283363",
		"1461446703485210103287273052203988822378723970341",
		userAddr,
		func(cur realm, amount0Delta, amount1Delta int64, _ *pool.CallbackMarker) error {
			return swap_wrapper.HandleSwapCallbackWithContext(
				token0Path,
				token1Path,
				userAddr,
				amount0Delta,
				amount1Delta,
			)
		},
	)
}
