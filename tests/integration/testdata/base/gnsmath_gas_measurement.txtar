gnokey maketx call -pkgpath gno.land/r/gnoswap/gnsmathgas -func TestGetLiquidityForAmounts -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1
