-- gnomod.toml --
module = "gno.land/r/test/avlkey"
gno = "0.9"
-- main.gno --
package avlkey

import (
	"strings"
	"strconv"

	"gno.land/p/nt/avl/v0"
)

type BigInt struct {
	arr [4]uint64
}

func NewBigInt(v uint64) *BigInt {
	return &BigInt{arr: [4]uint64{v, 0, 0, 0}}
}

type Info struct {
	A *BigInt
	B *BigInt
	C *BigInt
	D string
	E int64
}

var (
	tree    *avl.Tree
	counter int
)

func init() {
	tree = avl.NewTree()
}

// ============================================================
// Key generators
// ============================================================

func key1() string {
	return "k"
}

func key10() string {
	return "k_10chars_"
}

func key100() string {
	return "k_" + strings.Repeat("x", 98)
}

// ============================================================
// Background populate
// ============================================================

func PopulateBg(cur realm, n int) {
	tree = avl.NewTree()
	for i := 0; i < n; i++ {
		tree.Set("bg_"+strconv.Itoa(i), i)
	}
	counter = 0
}

// ============================================================
// INT value CRUD
// ============================================================

func IntCreate1(cur realm) {
	tree.Set(key1()+"_int_"+strconv.Itoa(counter), 42)
	counter++
}

func IntCreate10(cur realm) {
	tree.Set(key10()+"_int_"+strconv.Itoa(counter), 42)
	counter++
}

func IntCreate100(cur realm) {
	tree.Set(key100()+"_int_"+strconv.Itoa(counter), 42)
	counter++
}

func IntUpdate1(cur realm) {
	k := key1() + "_int_0"
	if _, ok := tree.Get(k); ok {
		tree.Set(k, 99999)
	}
}

func IntUpdate10(cur realm) {
	k := key10() + "_int_0"
	if _, ok := tree.Get(k); ok {
		tree.Set(k, 99999)
	}
}

func IntUpdate100(cur realm) {
	k := key100() + "_int_0"
	if _, ok := tree.Get(k); ok {
		tree.Set(k, 99999)
	}
}

func IntDelete1(cur realm) {
	tree.Remove(key1() + "_int_0")
}

func IntDelete10(cur realm) {
	tree.Remove(key10() + "_int_0")
}

func IntDelete100(cur realm) {
	tree.Remove(key100() + "_int_0")
}

// ============================================================
// STRUCT value CRUD
// ============================================================

func StructCreate1(cur realm) {
	tree.Set(key1()+"_st_"+strconv.Itoa(counter), &Info{
		A: NewBigInt(100), B: NewBigInt(200), C: NewBigInt(300),
		D: "gno.land/r/demo/pool:token0:token1:3000", E: 42,
	})
	counter++
}

func StructCreate10(cur realm) {
	tree.Set(key10()+"_st_"+strconv.Itoa(counter), &Info{
		A: NewBigInt(100), B: NewBigInt(200), C: NewBigInt(300),
		D: "gno.land/r/demo/pool:token0:token1:3000", E: 42,
	})
	counter++
}

func StructCreate100(cur realm) {
	tree.Set(key100()+"_st_"+strconv.Itoa(counter), &Info{
		A: NewBigInt(100), B: NewBigInt(200), C: NewBigInt(300),
		D: "gno.land/r/demo/pool:token0:token1:3000", E: 42,
	})
	counter++
}

func StructUpdate1(cur realm) {
	k := key1() + "_st_0"
	if v, ok := tree.Get(k); ok {
		s := v.(*Info)
		s.A = NewBigInt(99999)
	}
}

func StructUpdate10(cur realm) {
	k := key10() + "_st_0"
	if v, ok := tree.Get(k); ok {
		s := v.(*Info)
		s.A = NewBigInt(99999)
	}
}

func StructUpdate100(cur realm) {
	k := key100() + "_st_0"
	if v, ok := tree.Get(k); ok {
		s := v.(*Info)
		s.A = NewBigInt(99999)
	}
}

func StructDelete1(cur realm) {
	tree.Remove(key1() + "_st_0")
}

func StructDelete10(cur realm) {
	tree.Remove(key10() + "_st_0")
}

func StructDelete100(cur realm) {
	tree.Remove(key100() + "_st_0")
}
