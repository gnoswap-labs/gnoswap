## AVL Tree Key Length Storage Measurement
## Compares storage cost when avl.Tree keys are 1, 10, 100 chars
## Measures: Create / Update / Delete for int value and *struct value
## Scale factor: N = 1, 100

loadpkg gno.land/p/nt/avl/v0

gnoland start

# Deploy realm
gnokey maketx addpkg -pkgdir $WORK -pkgpath gno.land/r/test/avlkey -gas-fee 100000ugnot -gas-wanted 50000000 -broadcast -chainid=tendermint_test test1
stdout 'OK!'
stdout 'GAS USED:   4[0-9]{6}'
stdout 'STORAGE DELTA:  1[0-9]{4} bytes'
stdout 'STORAGE FEE:    1[0-9]{6}ugnot'
stdout 'TOTAL TX COST:  2[0-9]{6}ugnot'
stdout 'EVENTS:     \[\{\"bytes_delta\":[0-9]+,\"fee_delta\":\{\"denom\":\"ugnot\",\"amount\":[0-9]+\},\"pkg_path\":\"gno\.land/r/test/avlkey\"\}\]'

### ========== INT VALUE, N=1 ========== ###

gnokey maketx call -pkgpath gno.land/r/test/avlkey -func PopulateBg -args 1 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1
stdout 'OK!'
stdout 'GAS USED:   2[0-9]{6}'
stdout 'STORAGE DELTA:  9[0-9]{2} bytes'
stdout 'STORAGE FEE:    9[0-9]{4}ugnot'
stdout 'TOTAL TX COST:  1[0-9]{6}ugnot'
stdout 'EVENTS:     \[\{\"bytes_delta\":[0-9]+,\"fee_delta\":\{\"denom\":\"ugnot\",\"amount\":[0-9]+\},\"pkg_path\":\"gno\.land/r/test/avlkey\"\}\]'

