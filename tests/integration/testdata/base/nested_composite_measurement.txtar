## Nested Composite Data Structure Storage Measurement
## N = number of existing entries in the collection
## Measures: []Struct vs []*Struct, map[string]Struct vs map[string]*Struct, avl.Tree + struct
## Scale factor: N = 1, 100, 1,000

loadpkg gno.land/p/nt/avl/v0

gnoland start

# Deploy realm
gnokey maketx addpkg -pkgdir $WORK -pkgpath gno.land/r/test/nested -gas-fee 100000ugnot -gas-wanted 50000000 -broadcast -chainid=tendermint_test test1

### ========== []Struct vs []*Struct: N=1 ========== ###

# Populate value slice to 1
gnokey maketx call -pkgpath gno.land/r/test/nested -func PopulateValueSlice -args 1 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Populate pointer slice to 1
gnokey maketx call -pkgpath gno.land/r/test/nested -func PopulatePtrSlice -args 1 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# []Struct: Append one (N=1)
gnokey maketx call -pkgpath gno.land/r/test/nested -func ValueSliceAppend -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# []*Struct: Append one (N=1)
gnokey maketx call -pkgpath gno.land/r/test/nested -func PtrSliceAppend -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# []Struct: Update one (N=1)
gnokey maketx call -pkgpath gno.land/r/test/nested -func ValueSliceUpdate -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# []*Struct: Update one via pointer (N=1)
gnokey maketx call -pkgpath gno.land/r/test/nested -func PtrSliceUpdate -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# []Struct: Delete last (N=1)
gnokey maketx call -pkgpath gno.land/r/test/nested -func ValueSliceDelete -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# []*Struct: Delete last (N=1)
gnokey maketx call -pkgpath gno.land/r/test/nested -func PtrSliceDelete -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

