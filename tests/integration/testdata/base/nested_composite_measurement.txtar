-- gnomod.toml --
module = "gno.land/r/test/nested"
gno = "0.9"
-- main.gno --
package nested

import (
	"strconv"

	"gno.land/p/nt/avl/v0"
)

type Item struct {
	ID    int
	Name  string
	Value int
}

var (
	valueSlice []Item
	ptrSlice   []*Item

	valueMap  map[string]Item
	ptrMap    map[string]*Item
	stringMap map[string]string

	treeStruct *avl.Tree

	opCounter int
)

// ============ POPULATE ============

func PopulateValueSlice(cur realm, n int) {
	valueSlice = make([]Item, n)
	for i := 0; i < n; i++ {
		valueSlice[i] = Item{ID: i, Name: "item_" + strconv.Itoa(i), Value: i * 10}
	}
}

func PopulatePtrSlice(cur realm, n int) {
	ptrSlice = make([]*Item, n)
	for i := 0; i < n; i++ {
		ptrSlice[i] = &Item{ID: i, Name: "item_" + strconv.Itoa(i), Value: i * 10}
	}
}

func PopulateValueMap(cur realm, n int) {
	valueMap = make(map[string]Item)
	for i := 0; i < n; i++ {
		valueMap["key_"+strconv.Itoa(i)] = Item{ID: i, Name: "item_" + strconv.Itoa(i), Value: i * 10}
	}
	opCounter = n
}

func PopulatePtrMap(cur realm, n int) {
	ptrMap = make(map[string]*Item)
	for i := 0; i < n; i++ {
		ptrMap["key_"+strconv.Itoa(i)] = &Item{ID: i, Name: "item_" + strconv.Itoa(i), Value: i * 10}
	}
	opCounter = n
}

func PopulateTreeStruct(cur realm, n int) {
	treeStruct = avl.NewTree()
	for i := 0; i < n; i++ {
		treeStruct.Set("key_"+strconv.Itoa(i), &Item{ID: i, Name: "item_" + strconv.Itoa(i), Value: i * 10})
	}
	opCounter = n
}

// ============ []Struct CRUD ============

func ValueSliceAppend(cur realm) {
	valueSlice = append(valueSlice, Item{ID: 99999, Name: "new_item", Value: 99999})
}

func ValueSliceUpdate(cur realm) {
	if len(valueSlice) > 0 {
		valueSlice[0] = Item{ID: 0, Name: "updated_item", Value: 88888}
	}
}

func ValueSliceDelete(cur realm) {
	if len(valueSlice) > 0 {
		valueSlice = valueSlice[:len(valueSlice)-1]
	}
}

// ============ []*Struct CRUD ============

func PtrSliceAppend(cur realm) {
	ptrSlice = append(ptrSlice, &Item{ID: 99999, Name: "new_item", Value: 99999})
}

func PtrSliceUpdate(cur realm) {
	if len(ptrSlice) > 0 {
		ptrSlice[0].Name = "updated_item"
		ptrSlice[0].Value = 88888
	}
}

func PtrSliceDelete(cur realm) {
	if len(ptrSlice) > 0 {
		ptrSlice = ptrSlice[:len(ptrSlice)-1]
	}
}

// ============ map[string]Struct CRUD ============

func ValueMapCreate(cur realm) {
	valueMap["new_key_"+strconv.Itoa(opCounter)] = Item{ID: 99999, Name: "new_item", Value: 99999}
	opCounter++
}

func ValueMapUpdate(cur realm) {
	valueMap["key_0"] = Item{ID: 0, Name: "updated_item", Value: 88888}
}

func ValueMapDelete(cur realm) {
	delete(valueMap, "key_0")
}

// ============ map[string]*Struct CRUD ============

func PtrMapCreate(cur realm) {
	ptrMap["new_key_"+strconv.Itoa(opCounter)] = &Item{ID: 99999, Name: "new_item", Value: 99999}
	opCounter++
}

func PtrMapUpdate(cur realm) {
	if v, ok := ptrMap["key_0"]; ok {
		v.Name = "updated_item"
		v.Value = 88888
	}
}

func PtrMapDelete(cur realm) {
	delete(ptrMap, "key_0")
}

// ============ map[string]string CRUD ============

func PopulateStringMap(cur realm, n int) {
	stringMap = make(map[string]string)
	for i := 0; i < n; i++ {
		stringMap["key_"+strconv.Itoa(i)] = "value_" + strconv.Itoa(i*10)
	}
	opCounter = n
}

func StringMapCreate(cur realm) {
	stringMap["new_key_"+strconv.Itoa(opCounter)] = "new_value_99999"
	opCounter++
}

func StringMapUpdate(cur realm) {
	stringMap["key_0"] = "updated_short"
}

func StringMapUpdateSameLen(cur realm) {
	stringMap["key_0"] = "updated_samel"
}

func StringMapUpdateLonger(cur realm) {
	stringMap["key_0"] = "this_is_a_much_longer_value_string_that_should_increase_storage_cost_significantly"
}

func StringMapDelete(cur realm) {
	delete(stringMap, "key_0")
}

// ============ avl.Tree + *Struct CRUD ============

func TreeStructCreate(cur realm) {
	treeStruct.Set("new_key_"+strconv.Itoa(opCounter), &Item{ID: 99999, Name: "new_item", Value: 99999})
	opCounter++
}

func TreeStructUpdate(cur realm) {
	if v, ok := treeStruct.Get("key_0"); ok {
		item := v.(*Item)
		item.Name = "updated_item"
		item.Value = 88888
	}
}

func TreeStructDelete(cur realm) {
	treeStruct.Remove("key_0")
}
