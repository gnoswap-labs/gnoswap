# Persistent data-structure benchmark — authoritative gas evidence for GnoSwap.
#
# PURPOSE: Measure per-operation gas cost on PERSISTENT realm state with
# realistic struct values.  This is the single source of truth for
# "BPTree vs Map" decisions in GnoSwap.
#
# Methodology
# ===========
# - Package-level variables → realm persistence (serialize/deserialize each tx)
# - Populate in tx1, measure individual operations in tx2+ (isolated cost)
# - Values: 8-field struct (~200 bytes, matching TickInfo/Position)
# - Keys: 10-byte zero-padded (matching pool tick encoding)
# - Determinism: verified identical gas across 2 runs
#
# Baseline: Empty() = 1,386,261 gas (fixed per-tx overhead)
#
# ┌─────────────────────────────────────────────────────────────────────┐
# │                    RESULTS (net = gross - baseline)                 │
# ├──────────────┬───────────┬───────────┬───────────┬─────────────────┤
# │ Operation    │ BPTree32  │ BPTree64  │   Map     │ Winner          │
# ├──────────────┼───────────┼───────────┼───────────┼─────────────────┤
# │         N=100 (protocol_fee, small staker pools)                   │
# ├──────────────┼───────────┼───────────┼───────────┼─────────────────┤
# │ Populate     │  24.59M   │  23.72M   │  11.50M   │ Map   2.1x     │
# │ Single Get   │   2.70M   │   2.89M   │   0.96M   │ Map   2.8x     │
# │ Single Set   │   3.36M   │   3.55M   │   2.11M   │ Map   1.6x     │
# │ Iterate(10)  │   4.68M   │   4.87M   │    N/A    │ BPTree only    │
# │ RevIter(1)   │   2.72M   │   2.82M   │    N/A    │ BPTree only    │
# ├──────────────┼───────────┼───────────┼───────────┼─────────────────┤
# │         N=1000 (pool ticks, positions, referral)                   │
# ├──────────────┼───────────┼───────────┼───────────┼─────────────────┤
# │ Populate     │ 237.32M   │ 232.00M   │ 108.82M   │ Map   2.2x     │
# │ Single Get   │   3.09M   │   2.97M   │   6.30M   │ BPTree 2.0x    │
# │ Single Set   │   3.76M   │   3.63M   │  11.98M   │ BPTree 3.2x    │
# │ Iterate(10)  │   5.98M   │   5.71M   │    N/A    │ BPTree only    │
# │ RevIter(1)   │   3.12M   │   2.99M   │    N/A    │ BPTree only    │
# └──────────────┴───────────┴───────────┴───────────┴─────────────────┘
#
# ┌─────────────────────────────────────────────────────────────────────┐
# │              INCREMENTAL ADD (insert 1 new key, per-tx)            │
# │              This is the actual initialization pattern.            │
# ├──────────────┬───────────┬───────────┬─────────────────────────────┤
# │ Add 1 to     │ BPTree32  │   Map     │ Winner                      │
# ├──────────────┼───────────┼───────────┼─────────────────────────────┤
# │ N=100        │   3.38M   │   1.94M   │ Map   1.7x                  │
# │ N=1000       │   3.92M   │  11.85M   │ BPTree 3.0x                 │
# └──────────────┴───────────┴───────────┴─────────────────────────────┘
#
# Key finding: At N>=~500, Map's per-tx deserialization cost exceeds
# BPTree's tree-walk cost.  BPTree wins 2-3x for ALL operations
# (Get, Set, AND insert) on large persistent state.  Map only wins at N<~200.
#
# Decision rules
# ==============
# RULE 1: N < ~200 AND no ordering needed → Map
#         (protocol_fee, param_registry handlers, version_manager, etc.)
# RULE 2: N < ~200 AND ordering needed    → BPTree32
#         (fanout 64 has no benefit at this size)
# RULE 3: N >= ~200 (any access pattern)  → BPTree
#         (BPTree cheaper even for pure point queries due to persistence)
#         Use fanout 64 for ~4% saving at N>=1000.
# RULE 4: Iterate/ReverseIterate needed   → BPTree (only option).

loadpkg gno.land/p/nt/bptree/v0

## start a new node
gnoland start

gnokey maketx addpkg -pkgdir $WORK -pkgpath gno.land/r/test/persistbench -gas-fee 100000ugnot -gas-wanted 100000000 -broadcast -chainid=tendermint_test test1

### ============================================================ ###
### Baseline: Empty function (fixed per-tx overhead)             ###
### ============================================================ ###
gnokey maketx call -pkgpath gno.land/r/test/persistbench -func Empty -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1
# stdout 'GAS USED:   1386261'

### ============================================================ ###
### BPTree32 @ N=100                                             ###
### ============================================================ ###
# Populate 100 items (struct values, zero-padded keys)
gnokey maketx call -pkgpath gno.land/r/test/persistbench -func BPT32_Populate100 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1
# stdout 'GAS USED:   25974148'

# Single Get (from persisted tree of 100, middle key)
gnokey maketx call -pkgpath gno.land/r/test/persistbench -func BPT32_Get100 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1
# stdout 'GAS USED:   4085163'

# Single Set/Update (existing key in persisted tree of 100)
gnokey maketx call -pkgpath gno.land/r/test/persistbench -func BPT32_Set100 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1
# stdout 'GAS USED:   4742332'

# Iterate 10 items from middle of persisted tree of 100
gnokey maketx call -pkgpath gno.land/r/test/persistbench -func BPT32_Iterate10From100 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1
# stdout 'GAS USED:   6061299'

# ReverseIterate to find latest (from persisted tree of 100)
gnokey maketx call -pkgpath gno.land/r/test/persistbench -func BPT32_RevIter1From100 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1
# stdout 'GAS USED:   4105498'

# Reset for next data structure
gnokey maketx call -pkgpath gno.land/r/test/persistbench -func Reset -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1
# stdout 'GAS USED:   33962891'

### ============================================================ ###
### BPTree64 @ N=100                                             ###
### ============================================================ ###
gnokey maketx call -pkgpath gno.land/r/test/persistbench -func BPT64_Populate100 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1
# stdout 'GAS USED:   25109337'

gnokey maketx call -pkgpath gno.land/r/test/persistbench -func BPT64_Get100 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1
# stdout 'GAS USED:   4275312'

gnokey maketx call -pkgpath gno.land/r/test/persistbench -func BPT64_Set100 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1
# stdout 'GAS USED:   4932481'

gnokey maketx call -pkgpath gno.land/r/test/persistbench -func BPT64_Iterate10From100 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1
# stdout 'GAS USED:   6251693'

gnokey maketx call -pkgpath gno.land/r/test/persistbench -func BPT64_RevIter1From100 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1
# stdout 'GAS USED:   4203440'

gnokey maketx call -pkgpath gno.land/r/test/persistbench -func Reset -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1
