// ============================================================
// REALISTIC POSITION CRUD
// ============================================================

func PtrPositionCreate(cur realm) {
	ptrTree.Set("ptrpos_"+strconv.Itoa(counter), &PtrPosition{
		PoolKey:                  "gno.land/r/demo/token0:gno.land/r/demo/token1:3000",
		TickLower:                -887272,
		TickUpper:                887272,
		Liquidity:                NewBigInt(1000000),
		FeeGrowthInside0LastX128: NewBigInt(0),
		FeeGrowthInside1LastX128: NewBigInt(0),
		TokensOwed0:              NewBigInt(0),
		TokensOwed1:              NewBigInt(0),
		Burned:                   false,
	})
	counter++
}

func ValPositionCreate(cur realm) {
	valTree.Set("valpos_"+strconv.Itoa(counter), &ValPosition{
		PoolKey:                  "gno.land/r/demo/token0:gno.land/r/demo/token1:3000",
		TickLower:                -887272,
		TickUpper:                887272,
		Liquidity:                NewU256V(1000000),
		FeeGrowthInside0LastX128: NewU256V(0),
		FeeGrowthInside1LastX128: NewU256V(0),
		TokensOwed0:              NewU256V(0),
		TokensOwed1:              NewU256V(0),
		Burned:                   false,
	})
	counter++
}

func PtrPositionUpdateLiq(cur realm) {
	if v, ok := ptrTree.Get("ptrpos_0"); ok {
		s := v.(*PtrPosition)
		s.Liquidity = NewBigInt(9999999)
	}
}

func ValPositionUpdateLiq(cur realm) {
	if v, ok := valTree.Get("valpos_0"); ok {
		s := v.(*ValPosition)
		s.Liquidity = NewU256V(9999999)
	}
}

func PtrPositionUpdateAll(cur realm) {
	if v, ok := ptrTree.Get("ptrpos_0"); ok {
		s := v.(*PtrPosition)
		s.Liquidity = NewBigInt(7777777)
		s.FeeGrowthInside0LastX128 = NewBigIntFull(9999, 9999, 0, 0)
		s.FeeGrowthInside1LastX128 = NewBigIntFull(8888, 8888, 0, 0)
		s.TokensOwed0 = NewBigInt(11111)
		s.TokensOwed1 = NewBigInt(22222)
	}
}

func ValPositionUpdateAll(cur realm) {
	if v, ok := valTree.Get("valpos_0"); ok {
		s := v.(*ValPosition)
		s.Liquidity = NewU256V(7777777)
		s.FeeGrowthInside0LastX128 = NewU256VFull(9999, 9999, 0, 0)
		s.FeeGrowthInside1LastX128 = NewU256VFull(8888, 8888, 0, 0)
		s.TokensOwed0 = NewU256V(11111)
		s.TokensOwed1 = NewU256V(22222)
	}
}

func PtrPositionDelete(cur realm) {
	ptrTree.Remove("ptrpos_0")
}

func ValPositionDelete(cur realm) {
	valTree.Remove("valpos_0")
}
