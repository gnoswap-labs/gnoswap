-- gnomod.toml --
module = "gno.land/r/test/u256cmp"
gno = "0.9"
-- main.gno --
package u256cmp

import (
	"strconv"

	"gno.land/p/nt/avl/v0"
)

// ============================================================
// BigInt as pointer type (simulates *u256.Uint)
// ============================================================
type BigInt struct {
	arr [4]uint64
}

func NewBigInt(v uint64) *BigInt {
	return &BigInt{arr: [4]uint64{v, 0, 0, 0}}
}

func NewBigIntFull(a, b, c, d uint64) *BigInt {
	return &BigInt{arr: [4]uint64{a, b, c, d}}
}

// ============================================================
// U256V = value type (inline [4]uint64, no pointer indirection)
// ============================================================
type U256V [4]uint64

func NewU256V(v uint64) U256V {
	return U256V{v, 0, 0, 0}
}

func NewU256VFull(a, b, c, d uint64) U256V {
	return U256V{a, b, c, d}
}

// ============================================================
// Structs with 1 u256 field
// ============================================================
type PtrOne struct {
	Value *BigInt
}

type ValOne struct {
	Value U256V
}

// ============================================================
// Structs with 5 u256 fields (Position-like count)
// ============================================================
type PtrFive struct {
	F0 *BigInt
	F1 *BigInt
	F2 *BigInt
	F3 *BigInt
	F4 *BigInt
}

type ValFive struct {
	F0 U256V
	F1 U256V
	F2 U256V
	F3 U256V
	F4 U256V
}

// ============================================================
// Structs with 10 u256 fields (Pool-like count)
// ============================================================
type PtrTen struct {
	F0 *BigInt
	F1 *BigInt
	F2 *BigInt
	F3 *BigInt
	F4 *BigInt
	F5 *BigInt
	F6 *BigInt
	F7 *BigInt
	F8 *BigInt
	F9 *BigInt
}

type ValTen struct {
	F0 U256V
	F1 U256V
	F2 U256V
	F3 U256V
	F4 U256V
	F5 U256V
	F6 U256V
	F7 U256V
	F8 U256V
	F9 U256V
}

// ============================================================
// Realistic Position: pointer vs value
// ============================================================
type PtrPosition struct {
	PoolKey                  string
	TickLower                int32
	TickUpper                int32
	Liquidity                *BigInt
	FeeGrowthInside0LastX128 *BigInt
	FeeGrowthInside1LastX128 *BigInt
	TokensOwed0              *BigInt
	TokensOwed1              *BigInt
	Burned                   bool
}

type ValPosition struct {
	PoolKey                  string
	TickLower                int32
	TickUpper                int32
	Liquidity                U256V
	FeeGrowthInside0LastX128 U256V
	FeeGrowthInside1LastX128 U256V
	TokensOwed0              U256V
	TokensOwed1              U256V
	Burned                   bool
}

// ============================================================
// Storage
// ============================================================
var (
	bgTree   *avl.Tree
	ptrTree  *avl.Tree
	valTree  *avl.Tree
	counter  int
)

func init() {
	bgTree = avl.NewTree()
	ptrTree = avl.NewTree()
	valTree = avl.NewTree()
}

func PopulateBg(cur realm, n int) {
	bgTree = avl.NewTree()
	for i := 0; i < n; i++ {
		bgTree.Set("bg_"+strconv.Itoa(i), i)
	}
	// Reset test trees
	ptrTree = avl.NewTree()
	valTree = avl.NewTree()
	counter = 0
}

// ============================================================
// 1 FIELD CRUD
// ============================================================

func PtrOneCreate(cur realm) {
	ptrTree.Set("ptr1_"+strconv.Itoa(counter), &PtrOne{
		Value: NewBigInt(1000000),
	})
	counter++
}

func ValOneCreate(cur realm) {
	valTree.Set("val1_"+strconv.Itoa(counter), &ValOne{
		Value: NewU256V(1000000),
	})
	counter++
}

func PtrOneUpdate(cur realm) {
	if v, ok := ptrTree.Get("ptr1_0"); ok {
		s := v.(*PtrOne)
		s.Value = NewBigIntFull(99999, 88888, 77777, 66666)
	}
}

func ValOneUpdate(cur realm) {
	if v, ok := valTree.Get("val1_0"); ok {
		s := v.(*ValOne)
		s.Value = NewU256VFull(99999, 88888, 77777, 66666)
	}
}

func PtrOneDelete(cur realm) {
	ptrTree.Remove("ptr1_0")
}

func ValOneDelete(cur realm) {
	valTree.Remove("val1_0")
}

// ============================================================
// 5 FIELDS CRUD
// ============================================================

func PtrFiveCreate(cur realm) {
	ptrTree.Set("ptr5_"+strconv.Itoa(counter), &PtrFive{
		F0: NewBigInt(100), F1: NewBigInt(200), F2: NewBigInt(300),
		F3: NewBigInt(400), F4: NewBigInt(500),
	})
	counter++
}

func ValFiveCreate(cur realm) {
	valTree.Set("val5_"+strconv.Itoa(counter), &ValFive{
		F0: NewU256V(100), F1: NewU256V(200), F2: NewU256V(300),
		F3: NewU256V(400), F4: NewU256V(500),
	})
	counter++
}

func PtrFiveUpdateOne(cur realm) {
	if v, ok := ptrTree.Get("ptr5_0"); ok {
		s := v.(*PtrFive)
		s.F0 = NewBigIntFull(99999, 88888, 77777, 66666)
	}
}

func ValFiveUpdateOne(cur realm) {
	if v, ok := valTree.Get("val5_0"); ok {
		s := v.(*ValFive)
		s.F0 = NewU256VFull(99999, 88888, 77777, 66666)
	}
}

func PtrFiveUpdateAll(cur realm) {
	if v, ok := ptrTree.Get("ptr5_0"); ok {
		s := v.(*PtrFive)
		s.F0 = NewBigIntFull(11111, 22222, 33333, 44444)
		s.F1 = NewBigIntFull(55555, 66666, 77777, 88888)
		s.F2 = NewBigIntFull(99999, 11111, 22222, 33333)
		s.F3 = NewBigIntFull(44444, 55555, 66666, 77777)
		s.F4 = NewBigIntFull(88888, 99999, 11111, 22222)
	}
}

func ValFiveUpdateAll(cur realm) {
	if v, ok := valTree.Get("val5_0"); ok {
		s := v.(*ValFive)
		s.F0 = NewU256VFull(11111, 22222, 33333, 44444)
		s.F1 = NewU256VFull(55555, 66666, 77777, 88888)
		s.F2 = NewU256VFull(99999, 11111, 22222, 33333)
		s.F3 = NewU256VFull(44444, 55555, 66666, 77777)
		s.F4 = NewU256VFull(88888, 99999, 11111, 22222)
	}
}

func PtrFiveDelete(cur realm) {
	ptrTree.Remove("ptr5_0")
}

func ValFiveDelete(cur realm) {
	valTree.Remove("val5_0")
}

// ============================================================
// 10 FIELDS CRUD
// ============================================================

func PtrTenCreate(cur realm) {
	ptrTree.Set("ptr10_"+strconv.Itoa(counter), &PtrTen{
		F0: NewBigInt(100), F1: NewBigInt(200), F2: NewBigInt(300),
		F3: NewBigInt(400), F4: NewBigInt(500), F5: NewBigInt(600),
		F6: NewBigInt(700), F7: NewBigInt(800), F8: NewBigInt(900),
		F9: NewBigInt(1000),
	})
	counter++
}

func ValTenCreate(cur realm) {
	valTree.Set("val10_"+strconv.Itoa(counter), &ValTen{
		F0: NewU256V(100), F1: NewU256V(200), F2: NewU256V(300),
		F3: NewU256V(400), F4: NewU256V(500), F5: NewU256V(600),
		F6: NewU256V(700), F7: NewU256V(800), F8: NewU256V(900),
		F9: NewU256V(1000),
	})
	counter++
}

func PtrTenUpdateOne(cur realm) {
	if v, ok := ptrTree.Get("ptr10_0"); ok {
		s := v.(*PtrTen)
		s.F0 = NewBigIntFull(99999, 88888, 77777, 66666)
	}
}

func ValTenUpdateOne(cur realm) {
	if v, ok := valTree.Get("val10_0"); ok {
		s := v.(*ValTen)
		s.F0 = NewU256VFull(99999, 88888, 77777, 66666)
	}
}

func PtrTenUpdateAll(cur realm) {
	if v, ok := ptrTree.Get("ptr10_0"); ok {
		s := v.(*PtrTen)
		s.F0 = NewBigIntFull(11111, 22222, 33333, 44444)
		s.F1 = NewBigIntFull(55555, 66666, 77777, 88888)
		s.F2 = NewBigIntFull(99999, 11111, 22222, 33333)
		s.F3 = NewBigIntFull(44444, 55555, 66666, 77777)
		s.F4 = NewBigIntFull(88888, 99999, 11111, 22222)
		s.F5 = NewBigIntFull(12345, 23456, 34567, 45678)
		s.F6 = NewBigIntFull(56789, 67890, 78901, 89012)
		s.F7 = NewBigIntFull(90123, 12340, 23450, 34560)
		s.F8 = NewBigIntFull(45670, 56780, 67890, 78900)
		s.F9 = NewBigIntFull(89010, 90120, 12300, 23400)
	}
}

func ValTenUpdateAll(cur realm) {
	if v, ok := valTree.Get("val10_0"); ok {
		s := v.(*ValTen)
		s.F0 = NewU256VFull(11111, 22222, 33333, 44444)
		s.F1 = NewU256VFull(55555, 66666, 77777, 88888)
		s.F2 = NewU256VFull(99999, 11111, 22222, 33333)
		s.F3 = NewU256VFull(44444, 55555, 66666, 77777)
		s.F4 = NewU256VFull(88888, 99999, 11111, 22222)
		s.F5 = NewU256VFull(12345, 23456, 34567, 45678)
		s.F6 = NewU256VFull(56789, 67890, 78901, 89012)
		s.F7 = NewU256VFull(90123, 12340, 23450, 34560)
		s.F8 = NewU256VFull(45670, 56780, 67890, 78900)
