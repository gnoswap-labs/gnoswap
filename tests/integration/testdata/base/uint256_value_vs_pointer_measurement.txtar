## u256 Pointer vs Value Type Storage Measurement
## Compares *BigInt (pointer, simulating *u256.Uint) vs [4]uint64 (value, inline)
## Measures: Create / Update / Delete for varying pointer counts
## Scale factor: N = 1, 100

loadpkg gno.land/p/nt/avl/v0

gnoland start

# Deploy realm
gnokey maketx addpkg -pkgdir $WORK -pkgpath gno.land/r/test/u256cmp -gas-fee 100000ugnot -gas-wanted 50000000 -broadcast -chainid=tendermint_test test1

### ========== SINGLE FIELD: N=1 ========== ###

gnokey maketx call -pkgpath gno.land/r/test/u256cmp -func PopulateBg -args 1 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Pointer 1 field: Create (N=1)
gnokey maketx call -pkgpath gno.land/r/test/u256cmp -func PtrOneCreate -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Value 1 field: Create (N=1)
gnokey maketx call -pkgpath gno.land/r/test/u256cmp -func ValOneCreate -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Pointer 1 field: Update (N=1)
gnokey maketx call -pkgpath gno.land/r/test/u256cmp -func PtrOneUpdate -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Value 1 field: Update (N=1)
gnokey maketx call -pkgpath gno.land/r/test/u256cmp -func ValOneUpdate -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Pointer 1 field: Delete (N=1)
gnokey maketx call -pkgpath gno.land/r/test/u256cmp -func PtrOneDelete -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Value 1 field: Delete (N=1)
gnokey maketx call -pkgpath gno.land/r/test/u256cmp -func ValOneDelete -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

