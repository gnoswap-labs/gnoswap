## Pointer vs Value Struct Storage Measurement
## N = number of existing structs in background avl.Tree
## Compares: value struct vs pointer struct for Create / Update / Delete
## Also: nested pointer struct, partial field update
## Scale factor: N = 1, 100, 1,000

loadpkg gno.land/p/nt/avl/v0

gnoland start

# Deploy realm
gnokey maketx addpkg -pkgdir $WORK -pkgpath gno.land/r/test/ptrstorage -gas-fee 100000ugnot -gas-wanted 50000000 -broadcast -chainid=tendermint_test test1

### ========== N=1 ========== ###

# Populate 1 background entry
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func Populate -args 1 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

## Value struct (3 fields)
# Create value struct (N=1)
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func CreateValueSmall -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Update value struct (N=1)
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func UpdateValueSmall -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Delete value struct (N=1)
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func DeleteValueSmall -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

