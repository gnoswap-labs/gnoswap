# Update pointer struct - mutate fields (N=1)
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func UpdatePtrSmallMutate -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Update pointer struct - replace (N=1)
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func UpdatePtrSmallReplace -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Delete pointer struct - nil (N=1)
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func DeletePtrSmall -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

