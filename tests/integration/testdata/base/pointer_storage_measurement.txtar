## Pointer vs Value Struct Field-by-Field Storage Observation
## Creates single value/pointer/nested structs, then changes fields one at a time
## Compares: value struct vs *struct for each operation
## No background populate — minimal realm state

loadpkg gno.land/p/nt/avl/v0

gnoland start

# Deploy realm
gnokey maketx addpkg -pkgdir $WORK -pkgpath gno.land/r/test/ptrstorage -gas-fee 100000ugnot -gas-wanted 50000000 -broadcast -chainid=tendermint_test test1

### ========== BASELINE ========== ###

# Noop
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func Empty -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== VALUE STRUCT (3 fields): step-by-step ========== ###

# Value(3): Create
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func ValSmallCreate -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Value(3): Set field A
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func ValSmallSetA -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Value(3): Set field B
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func ValSmallSetB -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Value(3): Set field C
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func ValSmallSetC -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Value(3): Set all fields
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func ValSmallSetAll -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Value(3): Reset to zero
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func ValSmallReset -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== POINTER STRUCT (3 fields): step-by-step ========== ###

# Ptr(3): Create (allocate)
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func PtrSmallCreate -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Ptr(3): Mutate field A
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func PtrSmallMutateA -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Ptr(3): Mutate field B
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func PtrSmallMutateB -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Ptr(3): Mutate field C
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func PtrSmallMutateC -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Ptr(3): Replace (new pointer)
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func PtrSmallReplace -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Ptr(3): Set nil
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func PtrSmallNil -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Ptr(3): Restore from nil
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func PtrSmallRestore -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== VALUE STRUCT (10 fields): step-by-step ========== ###

# Value(10): Create
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func ValLargeCreate -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Value(10): Set 1 field
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func ValLargeSet1 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Value(10): Set 5 fields
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func ValLargeSet5 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Value(10): Set all 10 fields
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func ValLargeSetAll -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Value(10): Reset to zero
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func ValLargeReset -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== POINTER STRUCT (10 fields): step-by-step ========== ###

# Ptr(10): Create
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func PtrLargeCreate -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Ptr(10): Mutate 1 field
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func PtrLargeMutate1 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Ptr(10): Mutate 5 fields
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func PtrLargeMutate5 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Ptr(10): Mutate all 10 fields
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func PtrLargeMutateAll -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Ptr(10): Replace (new pointer)
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func PtrLargeReplace -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Ptr(10): Set nil
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func PtrLargeNil -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== NESTED POINTER: step-by-step ========== ###

# Nested: Create (3 *Inner fields)
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func NestedCreate -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Nested: Mutate Inner1.Value
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func NestedMutateInner1 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Nested: Mutate Inner2.Value
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func NestedMutateInner2 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Nested: Replace Inner1 (new pointer)
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func NestedReplaceInner1 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Nested: Replace entire struct
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func NestedReplaceAll -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Nested: Set nil
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func NestedNil -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Nested: Restore from nil
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func NestedRestore -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== PARTIAL UPDATE: value vs pointer side-by-side ========== ###

# Setup both value and pointer structs (10 fields each)
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func PartialSetup -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Partial: Value set 1 field (A only)
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func PartialVal1 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Partial: Pointer mutate 1 field (A only)
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func PartialPtr1 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Partial: Value set 3 fields (A, B, C)
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func PartialVal3 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Partial: Pointer mutate 3 fields (A, B, C)
gnokey maketx call -pkgpath gno.land/r/test/ptrstorage -func PartialPtr3 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

-- gnomod.toml --
module = "gno.land/r/test/ptrstorage"
gno = "0.9"
-- main.gno --
package ptrstorage

type Small struct {
	A int
	B int
	C int
}

type Large struct {
	A, B, C, D, E int
	F, G, H, I, J int
}

type Inner struct {
	Value int
	Name  string
}

type Nested struct {
	ID     int
	Label  string
	Inner1 *Inner
	Inner2 *Inner
	Inner3 *Inner
}

var (
	valueSmall Small
	ptrSmall   *Small

	valueLarge Large
	ptrLarge   *Large

	nested *Nested

	partialVal Large
	partialPtr *Large
)

func Empty(cur realm) {}

// ============================================================
// VALUE STRUCT (3 fields)
// ============================================================

func ValSmallCreate(cur realm) { valueSmall = Small{A: 1, B: 2, C: 3} }
func ValSmallSetA(cur realm)   { valueSmall.A = 100 }
func ValSmallSetB(cur realm)   { valueSmall.B = 200 }
func ValSmallSetC(cur realm)   { valueSmall.C = 300 }
func ValSmallSetAll(cur realm) { valueSmall = Small{A: 999, B: 888, C: 777} }
func ValSmallReset(cur realm)  { valueSmall = Small{} }

// ============================================================
// POINTER STRUCT (3 fields)
// ============================================================

func PtrSmallCreate(cur realm)  { ptrSmall = &Small{A: 1, B: 2, C: 3} }
func PtrSmallMutateA(cur realm) { ptrSmall.A = 100 }
func PtrSmallMutateB(cur realm) { ptrSmall.B = 200 }
func PtrSmallMutateC(cur realm) { ptrSmall.C = 300 }
func PtrSmallReplace(cur realm) { ptrSmall = &Small{A: 999, B: 888, C: 777} }
func PtrSmallNil(cur realm)     { ptrSmall = nil }
func PtrSmallRestore(cur realm) { ptrSmall = &Small{A: 1, B: 2, C: 3} }

// ============================================================
// VALUE STRUCT (10 fields)
// ============================================================

func ValLargeCreate(cur realm) {
	valueLarge = Large{A: 1, B: 2, C: 3, D: 4, E: 5, F: 6, G: 7, H: 8, I: 9, J: 10}
}

func ValLargeSet1(cur realm) { valueLarge.A = 999 }

func ValLargeSet5(cur realm) {
	valueLarge.A = 11
	valueLarge.B = 22
	valueLarge.C = 33
	valueLarge.D = 44
	valueLarge.E = 55
}

func ValLargeSetAll(cur realm) {
	valueLarge = Large{A: 100, B: 200, C: 300, D: 400, E: 500, F: 600, G: 700, H: 800, I: 900, J: 1000}
}

func ValLargeReset(cur realm) { valueLarge = Large{} }

// ============================================================
// POINTER STRUCT (10 fields)
// ============================================================

func PtrLargeCreate(cur realm) {
	ptrLarge = &Large{A: 1, B: 2, C: 3, D: 4, E: 5, F: 6, G: 7, H: 8, I: 9, J: 10}
}

func PtrLargeMutate1(cur realm) { ptrLarge.A = 999 }

func PtrLargeMutate5(cur realm) {
	ptrLarge.A = 11
	ptrLarge.B = 22
	ptrLarge.C = 33
	ptrLarge.D = 44
	ptrLarge.E = 55
}

func PtrLargeMutateAll(cur realm) {
	ptrLarge.A = 100
	ptrLarge.B = 200
	ptrLarge.C = 300
	ptrLarge.D = 400
	ptrLarge.E = 500
	ptrLarge.F = 600
	ptrLarge.G = 700
	ptrLarge.H = 800
	ptrLarge.I = 900
	ptrLarge.J = 1000
}

func PtrLargeReplace(cur realm) {
	ptrLarge = &Large{A: 111, B: 222, C: 333, D: 444, E: 555, F: 666, G: 777, H: 888, I: 999, J: 0}
}

func PtrLargeNil(cur realm) { ptrLarge = nil }

// ============================================================
// NESTED POINTER STRUCT
// ============================================================

func NestedCreate(cur realm) {
	nested = &Nested{
		ID: 1, Label: "position_001",
		Inner1: &Inner{Value: 100, Name: "fee_growth_0"},
		Inner2: &Inner{Value: 200, Name: "fee_growth_1"},
		Inner3: &Inner{Value: 300, Name: "liquidity"},
	}
}

func NestedMutateInner1(cur realm) { nested.Inner1.Value = 999 }
func NestedMutateInner2(cur realm) { nested.Inner2.Value = 888 }

func NestedReplaceInner1(cur realm) {
	nested.Inner1 = &Inner{Value: 5000, Name: "fee_growth_0_v2"}
}

func NestedReplaceAll(cur realm) {
	nested = &Nested{
		ID: 2, Label: "position_002",
		Inner1: &Inner{Value: 1000, Name: "new_inner1"},
		Inner2: &Inner{Value: 2000, Name: "new_inner2"},
		Inner3: &Inner{Value: 3000, Name: "new_inner3"},
	}
}

func NestedNil(cur realm)     { nested = nil }
func NestedRestore(cur realm) {
	nested = &Nested{
		ID: 1, Label: "restored",
		Inner1: &Inner{Value: 100, Name: "a"},
		Inner2: &Inner{Value: 200, Name: "b"},
		Inner3: &Inner{Value: 300, Name: "c"},
	}
}

// ============================================================
// PARTIAL UPDATE: value vs pointer
// ============================================================

func PartialSetup(cur realm) {
	partialVal = Large{A: 1, B: 2, C: 3, D: 4, E: 5, F: 6, G: 7, H: 8, I: 9, J: 10}
	partialPtr = &Large{A: 1, B: 2, C: 3, D: 4, E: 5, F: 6, G: 7, H: 8, I: 9, J: 10}
}

func PartialVal1(cur realm) { partialVal.A = 999 }
func PartialPtr1(cur realm) { partialPtr.A = 999 }

func PartialVal3(cur realm) {
	partialVal.A = 111
	partialVal.B = 222
	partialVal.C = 333
}

func PartialPtr3(cur realm) {
	partialPtr.A = 111
	partialPtr.B = 222
	partialPtr.C = 333
}
