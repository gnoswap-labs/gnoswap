-- gnomod.toml --
module = "gno.land/r/test/datastructgas"
gno = "0.9"
-- main.gno --
package datastructgas

import (
	"strconv"

	bptree "gno.land/p/nt/bptree/v0"
)

// Structs for testing
type SmallStruct struct {
	A int
	B int
	C int
}

type LargeStruct struct {
	A, B, C, D, E int
	F, G, H, I, J int
}

type XLargeStruct struct {
	A, B, C, D, E int
	F, G, H, I, J int
	K, L, M, N, O int
	P, Q, R, S, T int
}

func Empty(cur realm) {
	return
}

// ============ B+Tree Operations (fanout 32) ============

func BPTree32Insert10(cur realm) {
	tree := bptree.NewBPTreeN(32)
	for i := 0; i < 10; i++ {
		tree.Set(strconv.Itoa(i), i)
	}
}

func BPTree32Insert100(cur realm) {
	tree := bptree.NewBPTreeN(32)
	for i := 0; i < 100; i++ {
		tree.Set(strconv.Itoa(i), i)
	}
}

func BPTree32Insert1000(cur realm) {
	tree := bptree.NewBPTreeN(32)
	for i := 0; i < 1000; i++ {
		tree.Set(strconv.Itoa(i), i)
	}
}

func BPTree32Get10(cur realm) {
	tree := bptree.NewBPTreeN(32)
	for i := 0; i < 10; i++ {
		tree.Set(strconv.Itoa(i), i)
	}
	_, _ = tree.Get("5")
}

func BPTree32Get100(cur realm) {
	tree := bptree.NewBPTreeN(32)
	for i := 0; i < 100; i++ {
		tree.Set(strconv.Itoa(i), i)
	}
	_, _ = tree.Get("50")
}

func BPTree32Get1000(cur realm) {
	tree := bptree.NewBPTreeN(32)
	for i := 0; i < 1000; i++ {
		tree.Set(strconv.Itoa(i), i)
	}
	_, _ = tree.Get("500")
}

func BPTree32Iterate10(cur realm) {
	tree := bptree.NewBPTreeN(32)
	for i := 0; i < 10; i++ {
		tree.Set(strconv.Itoa(i), i)
	}
	sum := 0
	tree.Iterate("", "", func(key string, value interface{}) bool {
		sum += value.(int)
		return false
	})
}

func BPTree32Iterate100(cur realm) {
	tree := bptree.NewBPTreeN(32)
	for i := 0; i < 100; i++ {
		tree.Set(strconv.Itoa(i), i)
	}
	sum := 0
	tree.Iterate("", "", func(key string, value interface{}) bool {
		sum += value.(int)
		return false
	})
}

