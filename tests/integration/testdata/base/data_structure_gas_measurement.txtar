# Ephemeral data-structure cost — fanout sweep and raw operation baselines.
#
# PURPOSE: Measure INSERT / GET / ITERATE cost in local (non-persistent)
# variables.  Useful for comparing fanout 32 vs 64 vs 128 and for
# understanding one-time populate cost.
#
# IMPORTANT: These numbers do NOT include realm persistence (serialization)
# cost.  For "which data structure should I use?" decisions, refer to
# persistent_data_structure_benchmark.txtar instead.
#
# Fanout sweep results (ephemeral, int values):
#   N=10:   fanout has no effect (single leaf)
#   N=100:  64 ≈ -8% vs 32,  128 ≈ -16% vs 32
#   N=1000: 64 ≈ -8% vs 32,  128 ≈  -9% vs 32
#
# Guideline: 32→64 is nearly free ~8% past a single leaf.
# 64→128 pays off most in the 100-item range, diminishes past 1000.

loadpkg gno.land/p/nt/bptree/v0

## start a new node
gnoland start

gnokey maketx addpkg -pkgdir $WORK -pkgpath gno.land/r/test/datastructgas -gas-fee 100000ugnot -gas-wanted 50000000 -broadcast -chainid=tendermint_test test1

### Baseline ###
# Empty function (baseline)
gnokey maketx call -pkgpath gno.land/r/test/datastructgas -func Empty -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1
# stdout 'GAS USED:   1621521'

### B+Tree Operations (fanout 32) ###
## Insert
# B+Tree32 Insert 10 items
gnokey maketx call -pkgpath gno.land/r/test/datastructgas -func BPTree32Insert10 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1
# stdout 'GAS USED:   3940838'

# B+Tree32 Insert 100 items
gnokey maketx call -pkgpath gno.land/r/test/datastructgas -func BPTree32Insert100 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1
# stdout 'GAS USED:   13201468'

# B+Tree32 Insert 1000 items
gnokey maketx call -pkgpath gno.land/r/test/datastructgas -func BPTree32Insert1000 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1
# stdout 'GAS USED:   148280861'

