# Tree: Add 3rd entry
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func TreeAdd3rd -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Tree: Update 1st entry (same key, new value)
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func TreeUpdate1st -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Tree: Update 1st entry (larger value)
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func TreeUpdate1stLarger -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

