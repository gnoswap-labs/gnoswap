gnokey maketx call -pkgpath gno.land/r/test/collcrud -func SliceSetNil -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== AVL TREE: step-by-step ========== ###

# Tree: Init empty tree
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func TreeInit -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Tree: Add 1st entry
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func TreeAdd1st -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

