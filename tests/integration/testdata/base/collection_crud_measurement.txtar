-- gnomod.toml --
module = "gno.land/r/test/collcrud"
gno = "0.9"
-- main.gno --
package collcrud

import (
	"strconv"

	"gno.land/p/nt/avl/v0"
)

var (
	storedMap   map[string]int
	storedSlice []int
	storedTree  *avl.Tree

	opCounter int
)

// ============ POPULATE ============

func PopulateMap(cur realm, n int) {
	storedMap = make(map[string]int)
	for i := 0; i < n; i++ {
		storedMap["key_"+strconv.Itoa(i)] = i
	}
	opCounter = n
}

func PopulateSlice(cur realm, n int) {
	storedSlice = make([]int, n)
	for i := 0; i < n; i++ {
		storedSlice[i] = i
	}
	opCounter = n
}

func PopulateTree(cur realm, n int) {
	storedTree = avl.NewTree()
	for i := 0; i < n; i++ {
		storedTree.Set("key_"+strconv.Itoa(i), i)
	}
	opCounter = n
}

// ============ MAP CRUD ============

func MapCreateOne(cur realm) {
	storedMap["new_key_"+strconv.Itoa(opCounter)] = 99999
	opCounter++
}

func MapUpdateOne(cur realm) {
	storedMap["key_0"] = 88888
}

func MapDeleteOne(cur realm) {
	delete(storedMap, "key_0")
}

func MapSetNil(cur realm) {
	storedMap = nil
}

// ============ SLICE CRUD ============

func SliceAppendOne(cur realm) {
	storedSlice = append(storedSlice, 99999)
}

func SliceUpdateOne(cur realm) {
	if len(storedSlice) > 0 {
		storedSlice[0] = 88888
	}
}

func SliceShrinkOne(cur realm) {
	if len(storedSlice) > 0 {
		storedSlice = storedSlice[:len(storedSlice)-1]
	}
}

func SliceSetNil(cur realm) {
	storedSlice = nil
}

// ============ AVL TREE CRUD ============

func TreeCreateOne(cur realm) {
	storedTree.Set("new_key_"+strconv.Itoa(opCounter), 99999)
	opCounter++
}

func TreeUpdateOne(cur realm) {
	storedTree.Set("key_0", 88888)
}

func TreeDeleteOne(cur realm) {
	storedTree.Remove("key_0")
}
