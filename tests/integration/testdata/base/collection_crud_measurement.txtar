## Collection CRUD Storage Measurement
## N = number of existing entries in the collection
## Measures single-item Create / Update / Delete on: map, slice, avl.Tree
## Scale factor: N = 1, 100, 1,000

loadpkg gno.land/p/nt/avl/v0

gnoland start

# Deploy realm
gnokey maketx addpkg -pkgdir $WORK -pkgpath gno.land/r/test/collcrud -gas-fee 100000ugnot -gas-wanted 50000000 -broadcast -chainid=tendermint_test test1

### ========== MAP: N=1 ========== ###

# Populate map to 1 entry
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func PopulateMap -args 1 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Map: Create one entry (N=1)
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func MapCreateOne -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

