## Collection CRUD Field-by-Field Storage Observation
## Creates empty map / slice / avl.Tree, then performs one operation at a time
## Observes exact storage delta/gas for each individual mutation
## No bulk populate — pure single-operation observation

loadpkg gno.land/p/nt/avl/v0

gnoland start

# Deploy realm
gnokey maketx addpkg -pkgdir $WORK -pkgpath gno.land/r/test/collcrud -gas-fee 100000ugnot -gas-wanted 50000000 -broadcast -chainid=tendermint_test test1

### ========== BASELINE ========== ###

# Noop: empty function call
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func Empty -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== MAP: step-by-step ========== ###

# Map: Init empty map
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func MapInit -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Map: Add 1st entry
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func MapAdd1st -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Map: Add 2nd entry
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func MapAdd2nd -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Map: Add 3rd entry
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func MapAdd3rd -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Map: Update 1st entry (same value size)
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func MapUpdate1st -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Map: Update 1st entry (larger value)
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func MapUpdate1stLarger -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Map: Delete 1st entry
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func MapDelete1st -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Map: Delete 2nd entry
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func MapDelete2nd -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Map: Delete last entry (map becomes empty)
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func MapDeleteLast -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Map: Set nil
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func MapSetNil -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== SLICE: step-by-step ========== ###

# Slice: Init empty slice
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func SliceInit -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Slice: Append 1st element
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func SliceAppend1st -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Slice: Append 2nd element
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func SliceAppend2nd -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Slice: Append 3rd element
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func SliceAppend3rd -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Slice: Update 1st element (index 0)
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func SliceUpdate1st -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Slice: Update last element
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func SliceUpdateLast -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Slice: Shrink by 1 (remove last)
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func SliceShrink1 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Slice: Shrink to empty
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func SliceShrinkAll -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

