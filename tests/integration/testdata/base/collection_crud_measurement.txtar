# Tree: Delete last entry (tree becomes empty)
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func TreeDeleteLast -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== STRING VALUE comparison ========== ###

# Map: Add string value entry
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func MapAddString -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Tree: Add string value entry
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func TreeAddString -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Slice: Append string element
gnokey maketx call -pkgpath gno.land/r/test/collcrud -func SliceAppendString -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

-- gnomod.toml --
module = "gno.land/r/test/collcrud"
gno = "0.9"
-- main.gno --
package collcrud

import (
	"gno.land/p/nt/avl/v0"
)

var (
	storedMap    map[string]int
	storedSlice  []int
	storedTree   *avl.Tree

	strMap       map[string]string
	strSlice     []string
	strTree      *avl.Tree
	sink         interface{}
)

func init() {
	strMap = make(map[string]string)
	strSlice = []string{}
	strTree = avl.NewTree()
}

func Empty(cur realm) {}

// ============================================================
// MAP: step-by-step
// ============================================================

func MapInit(cur realm) {
	storedMap = make(map[string]int)
}

func MapAdd1st(cur realm) {
	storedMap["alpha"] = 100
}

func MapAdd2nd(cur realm) {
	storedMap["beta"] = 200
}

func MapAdd3rd(cur realm) {
	storedMap["gamma"] = 300
}

func MapUpdate1st(cur realm) {
	storedMap["alpha"] = 999 // same size int
}

func MapUpdate1stLarger(cur realm) {
	storedMap["alpha"] = 9999999999 // larger int
}

func MapDelete1st(cur realm) {
	delete(storedMap, "alpha")
}

func MapDelete2nd(cur realm) {
	delete(storedMap, "beta")
}

func MapDeleteLast(cur realm) {
	delete(storedMap, "gamma")
}

func MapSetNil(cur realm) {
	storedMap = nil
}

// ============================================================
// SLICE: step-by-step
// ============================================================

func SliceInit(cur realm) {
	storedSlice = []int{}
}

func SliceAppend1st(cur realm) {
	storedSlice = append(storedSlice, 100)
}

func SliceAppend2nd(cur realm) {
	storedSlice = append(storedSlice, 200)
}

func SliceAppend3rd(cur realm) {
	storedSlice = append(storedSlice, 300)
}

func SliceUpdate1st(cur realm) {
	storedSlice[0] = 999
}

func SliceUpdateLast(cur realm) {
	storedSlice[len(storedSlice)-1] = 888
}

func SliceShrink1(cur realm) {
	storedSlice = storedSlice[:len(storedSlice)-1]
}

func SliceShrinkAll(cur realm) {
	storedSlice = storedSlice[:0]
}

func SliceSetNil(cur realm) {
	storedSlice = nil
}

// ============================================================
// AVL TREE: step-by-step
// ============================================================

func TreeInit(cur realm) {
	storedTree = avl.NewTree()
}

func TreeAdd1st(cur realm) {
	storedTree.Set("alpha", 100)
}

func TreeAdd2nd(cur realm) {
	storedTree.Set("beta", 200)
}

func TreeAdd3rd(cur realm) {
	storedTree.Set("gamma", 300)
}

func TreeUpdate1st(cur realm) {
	storedTree.Set("alpha", 999) // same key, new value
}

func TreeUpdate1stLarger(cur realm) {
	storedTree.Set("alpha", 9999999999) // larger value
}

func TreeDelete1st(cur realm) {
	storedTree.Remove("alpha")
}

func TreeDelete2nd(cur realm) {
	storedTree.Remove("beta")
}

func TreeDeleteLast(cur realm) {
	storedTree.Remove("gamma")
}

// ============================================================
// STRING VALUE comparison
// ============================================================

func MapAddString(cur realm) {
	strMap["pool_path"] = "gno.land/r/demo/wugnot:gno.land/r/demo/gns:3000"
}

func TreeAddString(cur realm) {
	strTree.Set("pool_path", "gno.land/r/demo/wugnot:gno.land/r/demo/gns:3000")
}

func SliceAppendString(cur realm) {
	strSlice = append(strSlice, "gno.land/r/demo/wugnot:gno.land/r/demo/gns:3000")
}
