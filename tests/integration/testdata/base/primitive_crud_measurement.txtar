## Primitive Type CRUD Storage Measurement
## N = number of existing pkg-level vars already written (realm state size)
## Measures: Create / Update (grow & shrink) / Delete for int, uint64, string, bool, []byte
## Scale factor: N = 1, 100, 1,000

loadpkg gno.land/p/nt/avl/v0

gnoland start

# Deploy realm
gnokey maketx addpkg -pkgdir $WORK -pkgpath gno.land/r/test/primcrud -gas-fee 100000ugnot -gas-wanted 50000000 -broadcast -chainid=tendermint_test test1

### ========== N=1 (minimal realm state) ========== ###

# Populate 1 background variable
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func Populate -args 1 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Create int (N=1)
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func CreateInt -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Update int grow (N=1): 42 -> max int64
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func UpdateIntGrow -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Update int shrink (N=1): max int64 -> 1
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func UpdateIntShrink -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Delete int (N=1): 1 -> 0
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func DeleteInt -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Create string (N=1): "" -> 10 chars
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func CreateString -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Update string grow (N=1): 10 -> 1000 chars
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func UpdateStringGrow -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Update string shrink (N=1): 1000 -> 10 chars
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func UpdateStringShrink -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Delete string (N=1): 10 chars -> ""
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func DeleteString -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Create bool (N=1)
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func CreateBool -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Delete bool (N=1)
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func DeleteBool -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Create uint64 (N=1)
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func CreateUint64 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Update uint64 grow (N=1): 100 -> max uint64
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func UpdateUint64Grow -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Delete uint64 (N=1)
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func DeleteUint64 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Create bytes (N=1): nil -> 10 bytes
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func CreateBytes -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Update bytes grow (N=1): 10 -> 100 bytes
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func UpdateBytesGrow -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Delete bytes (N=1): -> nil
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func DeleteBytes -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

