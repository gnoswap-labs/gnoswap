## Primitive Type Field-by-Field Storage Observation
## Sets each package-level variable one at a time via setter
## Observes exact storage delta/gas for each individual change
## No background populate — minimal realm state

loadpkg gno.land/p/nt/avl/v0

gnoland start

# Deploy realm
gnokey maketx addpkg -pkgdir $WORK -pkgpath gno.land/r/test/primcrud -gas-fee 100000ugnot -gas-wanted 50000000 -broadcast -chainid=tendermint_test test1

### ========== BASELINE ========== ###

# Noop
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func Empty -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== INT ========== ###

# int: Set 0 -> 42
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func IntSet42 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# int: Set 42 -> 100
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func IntSet100 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# int: Set 100 -> max int64
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func IntSetMax -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# int: Set max int64 -> -1
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func IntSetNeg -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# int: Set -1 -> 0 (reset)
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func IntSetZero -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== UINT64 ========== ###

# uint64: Set 0 -> 100
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func Uint64Set100 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# uint64: Set 100 -> max uint64
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func Uint64SetMax -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# uint64: Set max -> 0 (reset)
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func Uint64SetZero -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== BOOL ========== ###

# bool: Set false -> true
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func BoolSetTrue -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# bool: Set true -> false
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func BoolSetFalse -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== STRING ========== ###

# string: Set "" -> "hello" (5 chars)
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func StringSetShort -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# string: Set "hello" -> "hello world!!" (13 chars, grow)
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func StringSetMedium -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# string: Set 13 chars -> 100 chars (grow)
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func StringSet100 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# string: Set 100 chars -> 1000 chars (grow large)
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func StringSet1000 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# string: Set 1000 chars -> 5 chars (shrink)
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func StringShrinkToShort -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# string: Set 5 chars -> same length different content
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func StringSameLen -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# string: Set -> "" (delete)
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func StringSetEmpty -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== []byte ========== ###

# []byte: Set nil -> 10 bytes
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func BytesSet10 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# []byte: Set 10 -> 100 bytes (grow)
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func BytesSet100 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# []byte: Set 100 -> 1000 bytes (grow large)
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func BytesSet1000 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# []byte: Set 1000 -> 10 bytes (shrink)
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func BytesShrinkTo10 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# []byte: Set 10 bytes -> nil (delete)
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func BytesSetNil -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== MULTIPLE VARS IN ONE TX ========== ###

# Set int + string + bool in one tx
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func SetMultiple3 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Set all 5 vars in one tx
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func SetAll5 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Reset all 5 vars to zero in one tx
gnokey maketx call -pkgpath gno.land/r/test/primcrud -func ResetAll5 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

-- gnomod.toml --
module = "gno.land/r/test/primcrud"
gno = "0.9"
-- main.gno --
package primcrud

import (
	"strings"
)

var (
	storedInt    int
	storedUint64 uint64
	storedBool   bool
	storedString string
	storedBytes  []byte
)

func Empty(cur realm) {}

// ============================================================
// INT
// ============================================================

func IntSet42(cur realm)   { storedInt = 42 }
func IntSet100(cur realm)  { storedInt = 100 }
func IntSetMax(cur realm)  { storedInt = 9223372036854775807 }
func IntSetNeg(cur realm)  { storedInt = -1 }
func IntSetZero(cur realm) { storedInt = 0 }

// ============================================================
// UINT64
// ============================================================

func Uint64Set100(cur realm)  { storedUint64 = 100 }
func Uint64SetMax(cur realm)  { storedUint64 = 18446744073709551615 }
func Uint64SetZero(cur realm) { storedUint64 = 0 }

// ============================================================
// BOOL
// ============================================================

func BoolSetTrue(cur realm)  { storedBool = true }
func BoolSetFalse(cur realm) { storedBool = false }

// ============================================================
// STRING
// ============================================================

func StringSetShort(cur realm)  { storedString = "hello" }
func StringSetMedium(cur realm) { storedString = "hello world!!" }
func StringSet100(cur realm)    { storedString = strings.Repeat("a", 100) }
func StringSet1000(cur realm)   { storedString = strings.Repeat("b", 1000) }
func StringShrinkToShort(cur realm) { storedString = "short" }
func StringSameLen(cur realm)       { storedString = "world" }
func StringSetEmpty(cur realm)      { storedString = "" }

// ============================================================
// []byte
// ============================================================

func BytesSet10(cur realm) {
	storedBytes = make([]byte, 10)
	for i := range storedBytes { storedBytes[i] = byte(i) }
}

func BytesSet100(cur realm) {
	storedBytes = make([]byte, 100)
	for i := range storedBytes { storedBytes[i] = byte(i % 256) }
}

func BytesSet1000(cur realm) {
	storedBytes = make([]byte, 1000)
	for i := range storedBytes { storedBytes[i] = byte(i % 256) }
}

func BytesShrinkTo10(cur realm) {
	storedBytes = make([]byte, 10)
	for i := range storedBytes { storedBytes[i] = byte(i + 100) }
}

func BytesSetNil(cur realm) { storedBytes = nil }

// ============================================================
// MULTIPLE VARS
// ============================================================

func SetMultiple3(cur realm) {
	storedInt = 42
	storedString = "hello"
	storedBool = true
}

func SetAll5(cur realm) {
	storedInt = 12345
	storedUint64 = 67890
	storedBool = true
	storedString = "all five vars set"
	storedBytes = []byte{1, 2, 3, 4, 5}
}

func ResetAll5(cur realm) {
	storedInt = 0
	storedUint64 = 0
	storedBool = false
	storedString = ""
	storedBytes = nil
}
