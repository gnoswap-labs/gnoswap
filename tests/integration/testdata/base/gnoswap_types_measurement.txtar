-- gnomod.toml --
module = "gno.land/r/test/gswtypes"
gno = "0.9"
-- main.gno --
package gswtypes

import (
	"gno.land/p/nt/avl/v0"
)

// BigInt simulates *u256.Uint / *i256.Int
type BigInt struct {
	arr [4]uint64
}

func NewBigInt(v uint64) *BigInt {
	return &BigInt{arr: [4]uint64{v, 0, 0, 0}}
}

func NewBigIntFull(a, b, c, d uint64) *BigInt {
	return &BigInt{arr: [4]uint64{a, b, c, d}}
}

// ---------- Slot0-like ----------
type Slot0 struct {
	SqrtPriceX96 *BigInt
	Tick         int32
	FeeProtocol  uint8
	Unlocked     bool
}

// ---------- Position-like ----------
type Position struct {
	PoolKey                  string
	TickLower                int32
	TickUpper                int32
	Liquidity                *BigInt
	FeeGrowthInside0LastX128 *BigInt
	FeeGrowthInside1LastX128 *BigInt
	TokensOwed0              *BigInt
	TokensOwed1              *BigInt
	Token0Balance            *BigInt
	Token1Balance            *BigInt
	Burned                   bool
}

// ---------- TickInfo-like ----------
type TickInfo struct {
	LiquidityGross                 *BigInt
	LiquidityNet                   *BigInt
	FeeGrowthOutside0X128          *BigInt
	FeeGrowthOutside1X128          *BigInt
	TickCumulativeOutside          int64
	SecondsPerLiquidityOutsideX128 *BigInt
	SecondsOutside                 uint32
	Initialized                    bool
}

// ---------- Pool-like ----------
type Pool struct {
	Token0Path           string
	Token1Path           string
	Fee                  uint32
	TickSpacing          int32
	Slot0                Slot0
	Balance0             *BigInt
	Balance1             *BigInt
	ProtocolFee0         *BigInt
	ProtocolFee1         *BigInt
	MaxLiquidityPerTick  *BigInt
	FeeGrowthGlobal0X128 *BigInt
	FeeGrowthGlobal1X128 *BigInt
	Liquidity            *BigInt
	Ticks                *avl.Tree
	Positions            *avl.Tree
}

var (
	positions *avl.Tree
	pools     *avl.Tree
	ticks     *avl.Tree
	sink      interface{}
)

func init() {
	positions = avl.NewTree()
	pools = avl.NewTree()
	ticks = avl.NewTree()
}

func Empty(cur realm) {}

// ============ POSITION ============

func PositionCreate(cur realm) {
	positions.Set("pos_0", &Position{
		PoolKey:                  "gno.land/r/demo/wugnot:gno.land/r/demo/gns:3000",
		TickLower:                -887272,
		TickUpper:                887272,
		Liquidity:                NewBigInt(0),
		FeeGrowthInside0LastX128: NewBigInt(0),
		FeeGrowthInside1LastX128: NewBigInt(0),
		TokensOwed0:              NewBigInt(0),
		TokensOwed1:              NewBigInt(0),
		Token0Balance:            NewBigInt(0),
		Token1Balance:            NewBigInt(0),
		Burned:                   false,
	})
}

func getPos() *Position {
	v, _ := positions.Get("pos_0")
	return v.(*Position)
}

func PosSetLiquidity(cur realm)    { getPos().Liquidity = NewBigInt(1000000) }
func PosSetFeeGrowth0(cur realm)   { getPos().FeeGrowthInside0LastX128 = NewBigIntFull(1000, 2000, 0, 0) }
func PosSetFeeGrowth1(cur realm)   { getPos().FeeGrowthInside1LastX128 = NewBigIntFull(3000, 4000, 0, 0) }
func PosSetTokensOwed0(cur realm)  { getPos().TokensOwed0 = NewBigInt(50000) }
func PosSetTokensOwed1(cur realm)  { getPos().TokensOwed1 = NewBigInt(60000) }
func PosSetToken0Balance(cur realm) { getPos().Token0Balance = NewBigInt(500000) }
func PosSetToken1Balance(cur realm) { getPos().Token1Balance = NewBigInt(600000) }
func PosSetBurned(cur realm)       { getPos().Burned = true }

func PosUpdateCollect(cur realm) {
	p := getPos()
	p.FeeGrowthInside0LastX128 = NewBigIntFull(9999, 8888, 0, 0)
	p.FeeGrowthInside1LastX128 = NewBigIntFull(7777, 6666, 0, 0)
	p.TokensOwed0 = NewBigInt(0)
	p.TokensOwed1 = NewBigInt(0)
}

func PosUpdateMint(cur realm) {
	p := getPos()
	p.Liquidity = NewBigInt(2000000)
	p.FeeGrowthInside0LastX128 = NewBigIntFull(11111, 22222, 0, 0)
	p.FeeGrowthInside1LastX128 = NewBigIntFull(33333, 44444, 0, 0)
}

func PosUpdateBurn(cur realm) {
	p := getPos()
	p.Liquidity = NewBigInt(0)
	p.TokensOwed0 = NewBigInt(99999)
	p.TokensOwed1 = NewBigInt(88888)
	p.Burned = true
}

func PosRemove(cur realm) {
	positions.Remove("pos_0")
}

// ============ POOL ============

func PoolCreate(cur realm) {
	pools.Set("pool_0", &Pool{
		Token0Path:           "gno.land/r/demo/wugnot",
		Token1Path:           "gno.land/r/demo/gns",
		Fee:                  3000,
		TickSpacing:          60,
		Slot0:                Slot0{SqrtPriceX96: NewBigIntFull(0, 1, 0, 0), Tick: 0, FeeProtocol: 0, Unlocked: true},
		Balance0:             NewBigInt(0),
		Balance1:             NewBigInt(0),
		ProtocolFee0:         NewBigInt(0),
		ProtocolFee1:         NewBigInt(0),
		MaxLiquidityPerTick:  NewBigIntFull(0, 0, 1, 0),
		FeeGrowthGlobal0X128: NewBigInt(0),
		FeeGrowthGlobal1X128: NewBigInt(0),
		Liquidity:            NewBigInt(0),
		Ticks:                avl.NewTree(),
		Positions:            avl.NewTree(),
	})
}

func getPool() *Pool {
	v, _ := pools.Get("pool_0")
	return v.(*Pool)
}

// Scalar setters
func PoolSetTick(cur realm)        { getPool().Slot0.Tick = 12345 }
func PoolSetFeeProtocol(cur realm) { getPool().Slot0.FeeProtocol = 5 }
func PoolSetUnlocked(cur realm)    { getPool().Slot0.Unlocked = false }

// Pointer setters (one at a time)
func PoolSetSqrtPrice(cur realm)    { getPool().Slot0.SqrtPriceX96 = NewBigIntFull(12345, 67890, 11111, 0) }
func PoolSetLiquidity(cur realm)    { getPool().Liquidity = NewBigInt(9999999) }
func PoolSetFeeGrowth0(cur realm)   { getPool().FeeGrowthGlobal0X128 = NewBigIntFull(11111, 22222, 33333, 0) }
func PoolSetFeeGrowth1(cur realm)   { getPool().FeeGrowthGlobal1X128 = NewBigIntFull(44444, 55555, 66666, 0) }
func PoolSetBalance0(cur realm)     { getPool().Balance0 = NewBigInt(5000000) }
func PoolSetBalance1(cur realm)     { getPool().Balance1 = NewBigInt(3000000) }
func PoolSetProtocolFee0(cur realm) { getPool().ProtocolFee0 = NewBigInt(1000) }
func PoolSetProtocolFee1(cur realm) { getPool().ProtocolFee1 = NewBigInt(2000) }
func PoolSetMaxLiqPerTick(cur realm) { getPool().MaxLiquidityPerTick = NewBigIntFull(0, 0, 2, 0) }

// Multi-field patterns
func PoolSwapMin(cur realm) {
	p := getPool()
	p.Slot0.SqrtPriceX96 = NewBigIntFull(22222, 33333, 0, 0)
	p.Slot0.Tick = 500
}

func PoolSwapFull(cur realm) {
	p := getPool()
	p.Slot0.SqrtPriceX96 = NewBigIntFull(44444, 55555, 0, 0)
	p.Slot0.Tick = -200
	p.Liquidity = NewBigInt(8888888)
	p.FeeGrowthGlobal0X128 = NewBigIntFull(55555, 66666, 0, 0)
	p.FeeGrowthGlobal1X128 = NewBigIntFull(77777, 88888, 0, 0)
}

func PoolSwapWithBalances(cur realm) {
	p := getPool()
	p.Slot0.SqrtPriceX96 = NewBigIntFull(66666, 77777, 0, 0)
	p.Slot0.Tick = 1000
	p.Liquidity = NewBigInt(7777777)
	p.FeeGrowthGlobal0X128 = NewBigIntFull(10000, 20000, 0, 0)
	p.FeeGrowthGlobal1X128 = NewBigIntFull(30000, 40000, 0, 0)
	p.Balance0 = NewBigInt(9000000)
	p.Balance1 = NewBigInt(8000000)
}

func PoolUpdateAll(cur realm) {
	p := getPool()
	p.Slot0.SqrtPriceX96 = NewBigIntFull(99999, 99999, 0, 0)
	p.Slot0.Tick = -887272
	p.Slot0.FeeProtocol = 10
	p.Liquidity = NewBigInt(1)
	p.FeeGrowthGlobal0X128 = NewBigIntFull(1, 1, 1, 1)
	p.FeeGrowthGlobal1X128 = NewBigIntFull(2, 2, 2, 2)
	p.Balance0 = NewBigInt(1)
	p.Balance1 = NewBigInt(1)
	p.ProtocolFee0 = NewBigInt(1)
	p.ProtocolFee1 = NewBigInt(1)
}

func PoolRemove(cur realm) {
	pools.Remove("pool_0")
}

// ============ TICK ============

func TickCreate(cur realm) {
	ticks.Set("tick_0", &TickInfo{
		LiquidityGross:                 NewBigInt(0),
		LiquidityNet:                   NewBigInt(0),
		FeeGrowthOutside0X128:          NewBigInt(0),
		FeeGrowthOutside1X128:          NewBigInt(0),
		TickCumulativeOutside:          0,
		SecondsPerLiquidityOutsideX128: NewBigInt(0),
		SecondsOutside:                 0,
		Initialized:                    false,
	})
}

func getTick() *TickInfo {
	v, _ := ticks.Get("tick_0")
	return v.(*TickInfo)
}

// Single-field setters
func TickSetLiqGross(cur realm)    { getTick().LiquidityGross = NewBigInt(500000) }
func TickSetLiqNet(cur realm)      { getTick().LiquidityNet = NewBigInt(250000) }
func TickSetFeeOutside0(cur realm) { getTick().FeeGrowthOutside0X128 = NewBigIntFull(1111, 2222, 0, 0) }
func TickSetFeeOutside1(cur realm) { getTick().FeeGrowthOutside1X128 = NewBigIntFull(3333, 4444, 0, 0) }
func TickSetCumOutside(cur realm)  { getTick().TickCumulativeOutside = 99999 }
func TickSetSecPerLiq(cur realm)   { getTick().SecondsPerLiquidityOutsideX128 = NewBigIntFull(5555, 6666, 0, 0) }
func TickSetSecOutside(cur realm)  { getTick().SecondsOutside = 12345 }
func TickSetInitialized(cur realm) { getTick().Initialized = true }

// Multi-field patterns
func TickCrossUpdate(cur realm) {
	t := getTick()
	t.LiquidityGross = NewBigInt(999999)
	t.LiquidityNet = NewBigInt(444444)
	t.FeeGrowthOutside0X128 = NewBigIntFull(7777, 8888, 0, 0)
	t.FeeGrowthOutside1X128 = NewBigIntFull(9999, 1111, 0, 0)
}

func TickInitialize(cur realm) {
	t := getTick()
	t.LiquidityGross = NewBigInt(1000000)
	t.LiquidityNet = NewBigInt(1000000)
	t.FeeGrowthOutside0X128 = NewBigIntFull(100, 200, 300, 400)
	t.FeeGrowthOutside1X128 = NewBigIntFull(500, 600, 700, 800)
	t.TickCumulativeOutside = 50000
	t.SecondsPerLiquidityOutsideX128 = NewBigIntFull(900, 1000, 0, 0)
	t.SecondsOutside = 86400
	t.Initialized = true
}

func TickRemove(cur realm) {
	ticks.Remove("tick_0")
}
