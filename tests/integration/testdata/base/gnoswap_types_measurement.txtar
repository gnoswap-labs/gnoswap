## GnoSwap Data Type Field-by-Field Storage Observation
## Creates single Pool / Position / Tick objects, then changes fields one at a time
## Observes exact storage delta/gas for each individual setter call
## No iteration — pure single-object observation

loadpkg gno.land/p/nt/avl/v0

gnoland start

# Deploy realm
gnokey maketx addpkg -pkgdir $WORK -pkgpath gno.land/r/test/gswtypes -gas-fee 100000ugnot -gas-wanted 50000000 -broadcast -chainid=tendermint_test test1

### ========== BASELINE ========== ###

# Noop: empty function call (baseline gas)
gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func Empty -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== POSITION: Create ========== ###

# Position: Create new
gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func PositionCreate -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== POSITION: field-by-field setters ========== ###

# Position: Set liquidity
gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func PosSetLiquidity -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Position: Set feeGrowthInside0LastX128
gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func PosSetFeeGrowth0 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Position: Set feeGrowthInside1LastX128
gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func PosSetFeeGrowth1 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Position: Set tokensOwed0
gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func PosSetTokensOwed0 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Position: Set tokensOwed1
gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func PosSetTokensOwed1 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Position: Set token0Balance
gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func PosSetToken0Balance -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Position: Set token1Balance
gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func PosSetToken1Balance -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Position: Set burned (bool)
gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func PosSetBurned -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== POSITION: multi-field update patterns ========== ###

# Position: Update collect (feeGrowth0 + feeGrowth1 + tokensOwed0 + tokensOwed1)
gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func PosUpdateCollect -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Position: Update mint (liquidity + feeGrowth0 + feeGrowth1)
gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func PosUpdateMint -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Position: Update burn (liquidity + tokensOwed0 + tokensOwed1 + burned)
gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func PosUpdateBurn -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Position: Remove from tree
gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func PosRemove -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== POOL: Create ========== ###

# Pool: Create new
gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func PoolCreate -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== POOL: scalar field setters ========== ###

