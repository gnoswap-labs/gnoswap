gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func PositionUpdateAll -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Position: Delete - set burned=true (N=1)
gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func PositionBurn -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

