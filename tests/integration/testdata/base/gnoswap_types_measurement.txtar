gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func PoolSetFeeGrowth0 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Pool: Set feeGrowthGlobal1X128
gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func PoolSetFeeGrowth1 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Pool: Set balance0
gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func PoolSetBalance0 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Pool: Set balance1
gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func PoolSetBalance1 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Pool: Set protocolFee0
gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func PoolSetProtocolFee0 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

