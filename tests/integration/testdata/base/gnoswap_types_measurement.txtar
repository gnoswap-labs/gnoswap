## GnoSwap Data Type Storage Measurement
## N = number of existing entries in the pools/positions tree
## Measures Create / Update / Delete for Pool-like and Position-like structs
## These types mirror the actual GnoSwap Pool and Position struct layouts
## with *BigInt fields (simulating *u256.Uint / *i256.Int)
## Scale factor: N = 1, 100, 1,000

loadpkg gno.land/p/nt/avl/v0

gnoland start

# Deploy realm
gnokey maketx addpkg -pkgdir $WORK -pkgpath gno.land/r/test/gswtypes -gas-fee 100000ugnot -gas-wanted 50000000 -broadcast -chainid=tendermint_test test1

### ========== POSITION-LIKE STRUCT: N=1 ========== ###

gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func PopulatePositions -args 1 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Position: Create (N=1)
gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func PositionCreate -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

