gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func PoolSetUnlocked -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

