# Pool: Set maxLiquidityPerTick
gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func PoolSetMaxLiqPerTick -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== POOL: multi-field update patterns ========== ###

# Pool: Swap minimal (sqrtPrice + tick)
gnokey maketx call -pkgpath gno.land/r/test/gswtypes -func PoolSwapMin -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

