## Mint Scenario Field-by-Field Storage Observation
## Creates a single Pool, then performs each Mint sub-operation one at a time
## Observes exact delta/gas for: bitmap, observation, tick, position, pool field updates
## Builds up state step-by-step to simulate first mint → add liquidity → new range

loadpkg gno.land/p/nt/avl/v0

gnoland start

# Deploy realm
gnokey maketx addpkg -pkgdir $WORK -pkgpath gno.land/r/test/mintsim -gas-fee 100000ugnot -gas-wanted 50000000 -broadcast -chainid=tendermint_test test1

### ========== BASELINE ========== ###

# Noop
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func Empty -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== POOL: Create empty pool ========== ###

# Pool: Create empty
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func PoolCreate -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== TICK BITMAP: individual operations ========== ###

# Bitmap: Add 1st word (new entry in bitmap tree)
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func BitmapAddWord -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Bitmap: Flip bit in existing word
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func BitmapFlipBit -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Bitmap: Clear bit (flip back)
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func BitmapClearBit -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Bitmap: Add 2nd word (different wordPos)
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func BitmapAddWord2 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== TICK: step-by-step creation ========== ###

# Tick: Create lower tick (tickLower = -100)
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func TickCreateLower -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Tick: Create upper tick (tickUpper = +100)
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func TickCreateUpper -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Tick: Update lower liquidityGross
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func TickUpdateLowerLiqGross -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Tick: Update lower liquidityNet
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func TickUpdateLowerLiqNet -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Tick: Update lower feeGrowthOutside0
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func TickUpdateLowerFee0 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Tick: Update lower feeGrowthOutside1
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func TickUpdateLowerFee1 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== POSITION: step-by-step ========== ###

# Position: Create new
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func PositionCreate -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Position: Set liquidity
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func PositionSetLiquidity -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Position: Set feeGrowthInside0
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func PositionSetFeeGrowth0 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Position: Set feeGrowthInside1
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func PositionSetFeeGrowth1 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== POOL FIELDS: one at a time after Mint ========== ###

# Pool: Set liquidity
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func PoolSetLiquidity -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Pool: Set feeGrowthGlobal0
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func PoolSetFeeGrowth0 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Pool: Set feeGrowthGlobal1
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func PoolSetFeeGrowth1 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Pool: Set sqrtPriceX96
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func PoolSetSqrtPrice -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Pool: Set tick
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func PoolSetTick -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== OBSERVATION: step-by-step ========== ###

# Observation: Init map (first observation)
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func ObsInit -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Observation: Append 2nd entry
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func ObsAppend2nd -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Observation: Append 3rd entry
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func ObsAppend3rd -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Observation: Overwrite existing (circular buffer)
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func ObsOverwrite -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== MINT SCENARIOS (composite) ========== ###

# First Mint: 2 ticks + 2 bitmaps + 1 position + pool liquidity (all new)
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func MintFirst -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Add Liquidity: same range (update existing ticks + position, no new objects)
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func MintAddLiquidity -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# New Range Mint: different ticks + new position (new objects + existing pool)
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func MintNewRange -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

### ========== CLEANUP ========== ###

# Remove position
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func PositionRemove -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Remove tick
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func TickRemoveLower -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

# Remove pool
gnokey maketx call -pkgpath gno.land/r/test/mintsim -func PoolRemove -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1

-- gnomod.toml --
module = "gno.land/r/test/mintsim"
gno = "0.9"
-- main.gno --
package mintsim

import (
	"gno.land/p/nt/avl/v0"
)

type BigInt struct {
	arr [4]uint64
}

func NewBigInt(v uint64) *BigInt {
	return &BigInt{arr: [4]uint64{v, 0, 0, 0}}
}

func NewBigIntFull(a, b, c, d uint64) *BigInt {
	return &BigInt{arr: [4]uint64{a, b, c, d}}
}

type TickInfo struct {
	LiquidityGross                 *BigInt
	LiquidityNet                   *BigInt
	FeeGrowthOutside0X128          *BigInt
	FeeGrowthOutside1X128          *BigInt
	TickCumulativeOutside          int64
	SecondsPerLiquidityOutsideX128 *BigInt
	SecondsOutside                 uint32
	Initialized                    bool
}

type PositionInfo struct {
	Liquidity                *BigInt
	FeeGrowthInside0LastX128 *BigInt
	FeeGrowthInside1LastX128 *BigInt
	TokensOwed0              *BigInt
	TokensOwed1              *BigInt
}

type Observation struct {
	BlockTimestamp                    int64
	TickCumulative                    int64
	LiquidityCumulative               *BigInt
	SecondsPerLiquidityCumulativeX128 *BigInt
	Initialized                       bool
}

type Pool struct {
	Token0Path           string
	Token1Path           string
	Fee                  uint32
	TickSpacing          int32
	SqrtPriceX96         *BigInt
	Tick                 int32
	FeeProtocol          uint8
	Unlocked             bool
	Balance0             *BigInt
	Balance1             *BigInt
	ProtocolFee0         *BigInt
	ProtocolFee1         *BigInt
	MaxLiquidityPerTick  *BigInt
	FeeGrowthGlobal0X128 *BigInt
	FeeGrowthGlobal1X128 *BigInt
	Liquidity            *BigInt
	Ticks                *avl.Tree
	TickBitmaps          *avl.Tree
	Positions            *avl.Tree
}

var (
	pools    *avl.Tree
	obsMap   map[uint16]*Observation
	obsIndex uint16
	sink     interface{}
)

func init() {
	pools = avl.NewTree()
	obsMap = make(map[uint16]*Observation)
}

func Empty(cur realm) {}

// ============================================================
// POOL
// ============================================================

func PoolCreate(cur realm) {
	pools.Set("pool_0", &Pool{
		Token0Path:           "gno.land/r/demo/wugnot",
		Token1Path:           "gno.land/r/demo/gns",
		Fee:                  3000,
		TickSpacing:          60,
		SqrtPriceX96:         NewBigIntFull(0, 1, 0, 0),
		Tick:                 0,
		FeeProtocol:          0,
		Unlocked:             true,
		Balance0:             NewBigInt(0),
		Balance1:             NewBigInt(0),
		ProtocolFee0:         NewBigInt(0),
		ProtocolFee1:         NewBigInt(0),
		MaxLiquidityPerTick:  NewBigIntFull(0, 0, 1, 0),
		FeeGrowthGlobal0X128: NewBigInt(0),
		FeeGrowthGlobal1X128: NewBigInt(0),
		Liquidity:            NewBigInt(0),
		Ticks:                avl.NewTree(),
		TickBitmaps:          avl.NewTree(),
		Positions:            avl.NewTree(),
	})
}

func getPool() *Pool {
	v, _ := pools.Get("pool_0")
	return v.(*Pool)
}

func PoolSetLiquidity(cur realm)  { getPool().Liquidity = NewBigInt(1000000) }
func PoolSetFeeGrowth0(cur realm) { getPool().FeeGrowthGlobal0X128 = NewBigIntFull(1111, 2222, 0, 0) }
func PoolSetFeeGrowth1(cur realm) { getPool().FeeGrowthGlobal1X128 = NewBigIntFull(3333, 4444, 0, 0) }
func PoolSetSqrtPrice(cur realm)  { getPool().SqrtPriceX96 = NewBigIntFull(12345, 67890, 0, 0) }
func PoolSetTick(cur realm)       { getPool().Tick = 500 }
func PoolRemove(cur realm)        { pools.Remove("pool_0") }

// ============================================================
// BITMAP
// ============================================================

func BitmapAddWord(cur realm) {
	getPool().TickBitmaps.Set("word_0", NewBigInt(0))
}

func BitmapFlipBit(cur realm) {
	p := getPool()
	if v, ok := p.TickBitmaps.Get("word_0"); ok {
		bm := v.(*BigInt)
		bm.arr[0] = bm.arr[0] ^ (1 << 42)
	}
}

func BitmapClearBit(cur realm) {
	p := getPool()
	if v, ok := p.TickBitmaps.Get("word_0"); ok {
		bm := v.(*BigInt)
		bm.arr[0] = bm.arr[0] ^ (1 << 42)
	}
}

func BitmapAddWord2(cur realm) {
	getPool().TickBitmaps.Set("word_1", NewBigInt(1 << 10))
}

// ============================================================
// TICK
// ============================================================

func newTick() *TickInfo {
	return &TickInfo{
		LiquidityGross: NewBigInt(0), LiquidityNet: NewBigInt(0),
		FeeGrowthOutside0X128: NewBigInt(0), FeeGrowthOutside1X128: NewBigInt(0),
		TickCumulativeOutside: 0, SecondsPerLiquidityOutsideX128: NewBigInt(0),
		SecondsOutside: 0, Initialized: false,
	}
}

func TickCreateLower(cur realm) { getPool().Ticks.Set("tick_-100", newTick()) }
func TickCreateUpper(cur realm) { getPool().Ticks.Set("tick_+100", newTick()) }

func getLowerTick() *TickInfo {
	v, _ := getPool().Ticks.Get("tick_-100")
	return v.(*TickInfo)
}

func TickUpdateLowerLiqGross(cur realm) { getLowerTick().LiquidityGross = NewBigInt(1000000) }
func TickUpdateLowerLiqNet(cur realm)   { getLowerTick().LiquidityNet = NewBigInt(1000000) }
func TickUpdateLowerFee0(cur realm)     { getLowerTick().FeeGrowthOutside0X128 = NewBigIntFull(100, 200, 0, 0) }
func TickUpdateLowerFee1(cur realm)     { getLowerTick().FeeGrowthOutside1X128 = NewBigIntFull(300, 400, 0, 0) }
func TickRemoveLower(cur realm)         { getPool().Ticks.Remove("tick_-100") }

// ============================================================
// POSITION
// ============================================================

func PositionCreate(cur realm) {
	getPool().Positions.Set("pos_first", &PositionInfo{
		Liquidity: NewBigInt(0), FeeGrowthInside0LastX128: NewBigInt(0),
		FeeGrowthInside1LastX128: NewBigInt(0), TokensOwed0: NewBigInt(0), TokensOwed1: NewBigInt(0),
	})
}

func getPosition() *PositionInfo {
	v, _ := getPool().Positions.Get("pos_first")
	return v.(*PositionInfo)
}

func PositionSetLiquidity(cur realm)  { getPosition().Liquidity = NewBigInt(1000000) }
func PositionSetFeeGrowth0(cur realm) { getPosition().FeeGrowthInside0LastX128 = NewBigIntFull(1111, 2222, 0, 0) }
func PositionSetFeeGrowth1(cur realm) { getPosition().FeeGrowthInside1LastX128 = NewBigIntFull(3333, 4444, 0, 0) }
func PositionRemove(cur realm)        { getPool().Positions.Remove("pos_first") }

// ============================================================
// OBSERVATION
// ============================================================

func ObsInit(cur realm) {
	obsMap = make(map[uint16]*Observation)
	obsMap[0] = &Observation{
		BlockTimestamp: 1000, TickCumulative: 0,
		LiquidityCumulative: NewBigInt(0), SecondsPerLiquidityCumulativeX128: NewBigInt(0),
		Initialized: true,
	}
	obsIndex = 0
}

func ObsAppend2nd(cur realm) {
	obsMap[1] = &Observation{
		BlockTimestamp: 2000, TickCumulative: 500,
		LiquidityCumulative: NewBigInt(1000000), SecondsPerLiquidityCumulativeX128: NewBigInt(500),
		Initialized: true,
	}
	obsIndex = 1
}

func ObsAppend3rd(cur realm) {
	obsMap[2] = &Observation{
		BlockTimestamp: 3000, TickCumulative: 1200,
		LiquidityCumulative: NewBigInt(2000000), SecondsPerLiquidityCumulativeX128: NewBigInt(1000),
		Initialized: true,
	}
	obsIndex = 2
}

func ObsOverwrite(cur realm) {
	obsMap[0] = &Observation{
		BlockTimestamp: 99999, TickCumulative: 88888,
		LiquidityCumulative: NewBigIntFull(11111, 22222, 0, 0),
		SecondsPerLiquidityCumulativeX128: NewBigIntFull(33333, 44444, 0, 0),
		Initialized: true,
	}
}

// ============================================================
// MINT SCENARIOS (composite)
// ============================================================

func MintFirst(cur realm) {
	p := getPool()
	p.Ticks.Set("tick_-200", &TickInfo{
		LiquidityGross: NewBigInt(500000), LiquidityNet: NewBigInt(500000),
		FeeGrowthOutside0X128: NewBigInt(0), FeeGrowthOutside1X128: NewBigInt(0),
		TickCumulativeOutside: 0, SecondsPerLiquidityOutsideX128: NewBigInt(0),
		SecondsOutside: 0, Initialized: true,
	})
	p.Ticks.Set("tick_+200", &TickInfo{
		LiquidityGross: NewBigInt(500000), LiquidityNet: NewBigInt(500000),
		FeeGrowthOutside0X128: NewBigInt(0), FeeGrowthOutside1X128: NewBigInt(0),
		TickCumulativeOutside: 0, SecondsPerLiquidityOutsideX128: NewBigInt(0),
		SecondsOutside: 0, Initialized: true,
	})
	p.TickBitmaps.Set("word_mint_neg", NewBigInt(1<<20))
	p.TickBitmaps.Set("word_mint_pos", NewBigInt(1<<30))
	p.Positions.Set("pos_mint", &PositionInfo{
		Liquidity: NewBigInt(500000), FeeGrowthInside0LastX128: NewBigInt(0),
		FeeGrowthInside1LastX128: NewBigInt(0), TokensOwed0: NewBigInt(0), TokensOwed1: NewBigInt(0),
	})
	p.Liquidity = NewBigInt(500000)
}

func MintAddLiquidity(cur realm) {
	p := getPool()
	if v, ok := p.Ticks.Get("tick_-200"); ok {
		t := v.(*TickInfo)
		t.LiquidityGross = NewBigInt(1000000)
		t.LiquidityNet = NewBigInt(1000000)
	}
	if v, ok := p.Ticks.Get("tick_+200"); ok {
		t := v.(*TickInfo)
		t.LiquidityGross = NewBigInt(1000000)
		t.LiquidityNet = NewBigInt(1000000)
	}
	if v, ok := p.Positions.Get("pos_mint"); ok {
		pos := v.(*PositionInfo)
		pos.Liquidity = NewBigInt(1000000)
	}
	p.Liquidity = NewBigInt(1000000)
}

func MintNewRange(cur realm) {
	p := getPool()
	p.Ticks.Set("tick_-500", &TickInfo{
		LiquidityGross: NewBigInt(300000), LiquidityNet: NewBigInt(300000),
		FeeGrowthOutside0X128: NewBigInt(0), FeeGrowthOutside1X128: NewBigInt(0),
		TickCumulativeOutside: 0, SecondsPerLiquidityOutsideX128: NewBigInt(0),
		SecondsOutside: 0, Initialized: true,
	})
	p.Ticks.Set("tick_+500", &TickInfo{
		LiquidityGross: NewBigInt(300000), LiquidityNet: NewBigInt(300000),
		FeeGrowthOutside0X128: NewBigInt(0), FeeGrowthOutside1X128: NewBigInt(0),
		TickCumulativeOutside: 0, SecondsPerLiquidityOutsideX128: NewBigInt(0),
		SecondsOutside: 0, Initialized: true,
	})
	p.TickBitmaps.Set("word_range2_neg", NewBigInt(1<<15))
	p.TickBitmaps.Set("word_range2_pos", NewBigInt(1<<25))
	p.Positions.Set("pos_range2", &PositionInfo{
		Liquidity: NewBigInt(300000), FeeGrowthInside0LastX128: NewBigInt(0),
		FeeGrowthInside1LastX128: NewBigInt(0), TokensOwed0: NewBigInt(0), TokensOwed1: NewBigInt(0),
	})
	p.Liquidity = NewBigInt(1300000)
}
