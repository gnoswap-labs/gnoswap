## Map vs AVL Tree benchmark for KVStore conversion PoC
## Compares gas and storage costs at small N (5, 10, 20, 30) typical of KVStore usage.
## Each scenario: initial populate, single-key update, read-then-update (dirty propagation).

loadpkg gno.land/p/nt/avl/v0

gnoland start

# Deploy benchmark realm
gnokey maketx addpkg -pkgdir $WORK -pkgpath gno.land/r/test/mapvsavl -gas-fee 100000ugnot -gas-wanted 50000000 -broadcast -chainid=tendermint_test test1



### Phase 1: Initial Population

# Map: populate 5 entries
gnokey maketx call -pkgpath gno.land/r/test/mapvsavl -func MapPopulate5 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1
stdout 'GAS USED'
stdout 'STORAGE DELTA'

# AVL: populate 5 entries
gnokey maketx call -pkgpath gno.land/r/test/mapvsavl -func AvlPopulate5 -insecure-password-stdin=true -broadcast=true -chainid=tendermint_test -gas-fee 1000000ugnot -gas-wanted 1000000000 -memo "" test1
stdout 'GAS USED'
stdout 'STORAGE DELTA'

