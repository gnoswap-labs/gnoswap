-- gnomod.toml --
module = "gno.land/r/test/mapvsavl"
gno = "0.9"
-- main.gno --
package mapvsavl

import (
	"strconv"

	"gno.land/p/nt/avl/v0"
)

// State: separate map and avl.Tree instances for each N

var (
	// Homogeneous int->int maps
	m5  map[string]int
	m10 map[string]int
	m20 map[string]int
	m30 map[string]int

	// Homogeneous int->int avl trees
	t5  *avl.Tree
	t10 *avl.Tree
	t20 *avl.Tree
	t30 *avl.Tree

	// Mixed-type (simulating KVStore pattern)
	mMixed map[string]any
	tMixed *avl.Tree
)

// Helper: key generator
func key(i int) string {
	return "k" + strconv.Itoa(i)
}


// Phase 1: Initial Population

func MapPopulate5(cur realm) {
	m5 = make(map[string]int)
	for i := 0; i < 5; i++ {
		m5[key(i)] = i * 100
	}
}

func AvlPopulate5(cur realm) {
	t5 = avl.NewTree()
	for i := 0; i < 5; i++ {
		t5.Set(key(i), i*100)
	}
}

func MapPopulate10(cur realm) {
	m10 = make(map[string]int)
	for i := 0; i < 10; i++ {
		m10[key(i)] = i * 100
	}
}

func AvlPopulate10(cur realm) {
	t10 = avl.NewTree()
	for i := 0; i < 10; i++ {
		t10.Set(key(i), i*100)
	}
}

func MapPopulate20(cur realm) {
	m20 = make(map[string]int)
	for i := 0; i < 20; i++ {
		m20[key(i)] = i * 100
	}
}

func AvlPopulate20(cur realm) {
	t20 = avl.NewTree()
	for i := 0; i < 20; i++ {
		t20.Set(key(i), i*100)
	}
}

func MapPopulate30(cur realm) {
	m30 = make(map[string]int)
	for i := 0; i < 30; i++ {
		m30[key(i)] = i * 100
	}
}

func AvlPopulate30(cur realm) {
	t30 = avl.NewTree()
	for i := 0; i < 30; i++ {
		t30.Set(key(i), i*100)
	}
}


// Phase 2: Single Key Update (only write 1 key)

func MapUpdate5(cur realm) {
	m5[key(2)] = 9999
}

func AvlUpdate5(cur realm) {
	t5.Set(key(2), 9999)
}

func MapUpdate10(cur realm) {
	m10[key(5)] = 9999
}

func AvlUpdate10(cur realm) {
	t10.Set(key(5), 9999)
}

func MapUpdate20(cur realm) {
	m20[key(10)] = 9999
}

func AvlUpdate20(cur realm) {
	t20.Set(key(10), 9999)
}

func MapUpdate30(cur realm) {
	m30[key(15)] = 9999
}

func AvlUpdate30(cur realm) {
	t30.Set(key(15), 9999)
}


// Phase 3: Read N-1 keys, then Update 1 key
// (Simulates KVStore: check multiple values then write one)

func MapReadThenUpdate5(cur realm) {
	sum := 0
	for i := 0; i < 4; i++ {
		sum += m5[key(i)]
	}
	m5[key(4)] = sum
}

func AvlReadThenUpdate5(cur realm) {
	sum := 0
	for i := 0; i < 4; i++ {
		v, _ := t5.Get(key(i))
		sum += v.(int)
	}
	t5.Set(key(4), sum)
}

func MapReadThenUpdate10(cur realm) {
	sum := 0
	for i := 0; i < 9; i++ {
		sum += m10[key(i)]
	}
	m10[key(9)] = sum
}

func AvlReadThenUpdate10(cur realm) {
	sum := 0
	for i := 0; i < 9; i++ {
		v, _ := t10.Get(key(i))
		sum += v.(int)
	}
	t10.Set(key(9), sum)
}

func MapReadThenUpdate20(cur realm) {
	sum := 0
	for i := 0; i < 19; i++ {
		sum += m20[key(i)]
	}
	m20[key(19)] = sum
}

func AvlReadThenUpdate20(cur realm) {
	sum := 0
	for i := 0; i < 19; i++ {
		v, _ := t20.Get(key(i))
		sum += v.(int)
	}
	t20.Set(key(19), sum)
}

func MapReadThenUpdate30(cur realm) {
	sum := 0
	for i := 0; i < 29; i++ {
		sum += m30[key(i)]
	}
	m30[key(29)] = sum
}

func AvlReadThenUpdate30(cur realm) {
	sum := 0
	for i := 0; i < 29; i++ {
		v, _ := t30.Get(key(i))
		sum += v.(int)
	}
	t30.Set(key(29), sum)
}


// Phase 4: Read-Only (no writes — check dirty marking behavior)

func MapReadOnly20(cur realm) int {
	sum := 0
	for i := 0; i < 20; i++ {
		sum += m20[key(i)]
	}
	return sum
}

func AvlReadOnly20(cur realm) int {
	sum := 0
	for i := 0; i < 20; i++ {
		v, _ := t20.Get(key(i))
		sum += v.(int)
	}
	return sum
}

func MapReadOnly30(cur realm) int {
	sum := 0
	for i := 0; i < 30; i++ {
		sum += m30[key(i)]
	}
	return sum
}

func AvlReadOnly30(cur realm) int {
	sum := 0
	for i := 0; i < 30; i++ {
		v, _ := t30.Get(key(i))
		sum += v.(int)
	}
	return sum
}


// Phase 5: Mixed-type values (simulates real KVStore)

type Config struct {
	Name    string
	Value   int64
	Enabled bool
}

func MapPopulateMixed(cur realm) {
	mMixed = make(map[string]any)
	for i := 0; i < 8; i++ {
		mMixed["int_"+key(i)] = int64(i * 100)
	}
	for i := 0; i < 6; i++ {
		mMixed["str_"+key(i)] = "value_" + strconv.Itoa(i)
	}
	for i := 0; i < 3; i++ {
		mMixed["bool_"+key(i)] = i%2 == 0
	}
	for i := 0; i < 3; i++ {
		mMixed["cfg_"+key(i)] = Config{
			Name:    "config_" + strconv.Itoa(i),
			Value:   int64(i * 1000),
			Enabled: true,
		}
	}
}

func AvlPopulateMixed(cur realm) {
	tMixed = avl.NewTree()
	for i := 0; i < 8; i++ {
		tMixed.Set("int_"+key(i), int64(i*100))
	}
	for i := 0; i < 6; i++ {
		tMixed.Set("str_"+key(i), "value_"+strconv.Itoa(i))
	}
	for i := 0; i < 3; i++ {
		tMixed.Set("bool_"+key(i), i%2 == 0)
	}
	for i := 0; i < 3; i++ {
		tMixed.Set("cfg_"+key(i), Config{
			Name:    "config_" + strconv.Itoa(i),
			Value:   int64(i * 1000),
			Enabled: true,
		})
	}
}

func MapUpdateMixed(cur realm) {
	mMixed["int_"+key(3)] = int64(7777)
}

func AvlUpdateMixed(cur realm) {
	tMixed.Set("int_"+key(3), int64(7777))
}
