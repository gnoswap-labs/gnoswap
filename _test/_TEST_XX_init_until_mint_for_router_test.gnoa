// 1 hop
// t1:t2:100
func TestDrySwapRouteSingleHopToken1Token2LowFee(t *testing.T) {
	std.TestSetOrigCaller(test1)

	dryResult := rou.DrySwapRoute(
		token01Path,         // inputToken
		token02Path,         // outputToken
		bigint(100_000_000), // amountSpecified
		"EXACT_IN",          // swapType
		"gno.land/r/demo/token01:gno.land/r/demo/token02:100", // strRouteArr
		"100", // quoteArr
	)

	shouldEQ(t, dryResult, bigint(99_989_753))
}

// 1 hop
// t1:t2:10000
func TestDrySwapRouteSingleHopToken1Token2HighFee(t *testing.T) {
