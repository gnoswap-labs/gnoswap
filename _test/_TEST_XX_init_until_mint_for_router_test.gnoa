package swap_scneraio

import (
	"std"
	"testing"

	_ "gno.land/r/demo/grc20_wrapper"

	pl "gno.land/r/demo/pool"
	pos "gno.land/r/demo/position"
	rou "gno.land/r/demo/router"

	"gno.land/r/demo/gns"
	"gno.land/r/demo/token01"
	"gno.land/r/demo/token02"
	"gno.land/r/demo/token03"
	"gno.land/r/demo/token04"
	"gno.land/r/demo/token05"
	"gno.land/r/demo/token06"
	"gno.land/r/demo/token07"
	"gno.land/r/demo/token08"
	"gno.land/r/demo/token09"
	"gno.land/r/demo/token10"
)

var (
	test1 = std.Address("g1jg8mtutu9khhfwc4nxmuhcpftf0pajdhfvsqf5")

	poolAddr     = std.DerivePkgAddr("gno.land/r/demo/pool")
	positionAddr = std.DerivePkgAddr("gno.land/r/demo/position")
	stakerAddr   = std.DerivePkgAddr("gno.land/r/demo/staker")
	routerAddr   = std.DerivePkgAddr("gno.land/r/demo/router")

	token01Path = "gno.land/r/demo/token01"
	token02Path = "gno.land/r/demo/token02"
	token03Path = "gno.land/r/demo/token03"
	token04Path = "gno.land/r/demo/token04"
	token05Path = "gno.land/r/demo/token05"
	token06Path = "gno.land/r/demo/token06"
	token07Path = "gno.land/r/demo/token07"
	token08Path = "gno.land/r/demo/token08"
	token09Path = "gno.land/r/demo/token09"
	token10Path = "gno.land/r/demo/token10"

	max_timeout = bigint(9999999999)
)

func TestPoolInitByAdmin(t *testing.T) {
	std.TestSetOrigCaller(test1)

	pl.InitManual()
	std.TestSkipHeights(1)
}

func TestPoolCreatePools(t *testing.T) {
	std.TestSetOrigCaller(test1)

	// approve gns to CreatePool ( 500 gns for 1 pool)
	gns.Approve(a2u(poolAddr), 500*13)

	pl.CreatePool(token01Path, token02Path, 100, 79228162514264337593543950337)    // tick 0 ≈ x1
	pl.CreatePool(token02Path, token03Path, 100, 177166786517138269218369076073)   // tick 16096 ≈ x5
	pl.CreatePool(token01Path, token02Path, 10000, 79228162514264337593543950337)  // tick 0 ≈ x1
	pl.CreatePool(token02Path, token03Path, 10000, 194073514576992249379660408880) // tick 17979 ≈ x6
	pl.CreatePool(token04Path, token05Path, 100, 25054147597456445214093764435)    // tick -23027 ≈ x0.1
	pl.CreatePool(token05Path, token06Path, 100, 17716682555034377259603427773)    // tick -9958 ≈ x0.5
	pl.CreatePool(token04Path, token05Path, 10000, 25054147597456445214093764435)  // tick -23027 ≈ x0.1
	pl.CreatePool(token05Path, token06Path, 10000, 19407355733507081572369655227)  // tick -28135 ≈ x0.6
	pl.CreatePool(token03Path, token08Path, 3000, 5602503859762671191748202504234) // tick 85176 ≈ x5000
	pl.CreatePool(token06Path, token10Path, 3000, 5602507562777276312411137859)    // tick -25985 ≈ x0.005

	pl.CreatePool(token07Path, token08Path, 100, 112046559425783515914356180039)   // 6932 ≈ x2
	pl.CreatePool(token07Path, token08Path, 10000, 250541420775534450580036817218) // 23027 ≈ x10
	pl.CreatePool(token08Path, token09Path, 100, 177166786517138269218369076073)   // 16096 ≈x5

	std.TestSkipHeights(4)
}

func TestApproveAll(t *testing.T) {
	std.TestSetOrigCaller(test1)

	token01.Approve(a2u(poolAddr), 10_000_000_000_000_000)
	token02.Approve(a2u(poolAddr), 10_000_000_000_000_000)
	token03.Approve(a2u(poolAddr), 10_000_000_000_000_000)
	token04.Approve(a2u(poolAddr), 10_000_000_000_000_000)
	token05.Approve(a2u(poolAddr), 10_000_000_000_000_000)
	token06.Approve(a2u(poolAddr), 10_000_000_000_000_000)
	token07.Approve(a2u(poolAddr), 10_000_000_000_000_000)
	token08.Approve(a2u(poolAddr), 10_000_000_000_000_000)
	token09.Approve(a2u(poolAddr), 10_000_000_000_000_000)
	token10.Approve(a2u(poolAddr), 10_000_000_000_000_000)
}

func TestPosition1InRange(t *testing.T) {
	std.TestSetOrigCaller(test1)

	tokenId, liquidity, amount0, amount1 := pos.Mint(
		token01Path,       // token0
		token02Path,       // token1
		100,               // fee
		-500,              // tickLower
		500,               // tickUpper
		1_000_000_000_000, // amount0Desired
		1_000_000_000_000, // amount1Desired
		0,                 // amount0Min
		0,                 // amount1Min
		max_timeout,       // deadline
	)

	shouldEQ(t, tokenId, bigint(1))
	shouldEQ(t, amount0, bigint(999_999_999_999))
	shouldEQ(t, amount1, bigint(999_999_999_999))

	std.TestSkipHeights(3)
}

