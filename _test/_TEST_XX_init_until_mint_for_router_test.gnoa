func TestDrySwapRouteSingleHopSingleRouteToken7Token8RpcFail(t *testing.T) {
	std.TestSetOrigCaller(test1)

	// test => 1748 iteration => return -1
	// land => 1325 iteration => panic("allocation limit")
	dryResult := rou.DrySwapRoute(
		token07Path,         // inputToken
		token08Path,         // outputToken
		bigint(530_000_000), // amountSpecified
		"EXACT_IN",          // swapType
		"gno.land/r/demo/token07:gno.land/r/demo/token08:100", // strRouteArr
		"100", // quoteArr
	)
	println("dryResult:", dryResult) // -1
	// RPC
	/*
			{
		    "jsonrpc": "2.0",
		    "id": "",
		    "error": {
		        "code": -32603,
		        "message": "Internal error",
		        "data": "allocation limit exceeded"
		    }
		}
	*/
}
